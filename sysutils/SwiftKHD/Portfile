# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           github 1.0

github.setup        trodemaster SwiftKHD 0.1.4 v
github.tarball_from archive
revision            0

categories          sysutils
platforms           {darwin >= 22}
license             MIT
maintainers         {@trodemaster icloud.com:manuals-unread2u} openmaintainer

description         Simple hotkey daemon for macOS written in Swift
long_description    SwiftKHD is a Swift port of skhd, a simple hotkey daemon \
                    for macOS. Fully compatible with existing skhd configuration \
                    files. Features modal hotkeys, process-specific bindings, key \
                    forwarding, media key support, and live config hot reload.

checksums           rmd160  af38f04d216d04affca8645dcf22729c2b7d5410 \
                    sha256  3f40757c35bd07d1e41c0fdf68fc9391ce845791ffa9d3e43c8af947687eeae5 \
                    size    40650

conflicts           skhd skhd.zig

use_configure       no
use_xcode           yes

build.cmd           swift
build.target        build
build.args          --configuration release \
                    --arch ${configure.build_arch} \
                    --disable-sandbox

test.cmd            swift
test.target         test
test.args           --disable-sandbox

variant tests description {Run the test suite} {
    test.run        yes
}

destroot {
    xinstall -m 0755 \
        ${worksrcpath}/.build/${configure.build_arch}-apple-macosx/release/SwiftKHD \
        ${destroot}${prefix}/bin/swiftkhd

    set docdir ${destroot}${prefix}/share/doc/${name}
    xinstall -d ${docdir}
    xinstall -m 0644 ${worksrcpath}/README.md ${docdir}
    xinstall -m 0644 ${worksrcpath}/LICENSE   ${docdir}
}

notes "
To get started:

1. Install the launchd service:
   swiftkhd --install-service

2. Grant accessibility permissions:
   System Settings > Privacy & Security > Accessibility > add SwiftKHD

3. Create your config at ~/.config/skhd/skhdrc (same format as skhd)

To reload config while running:
   swiftkhd --reload

To check service status:
   swiftkhd --status
"
