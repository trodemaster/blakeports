+	case "vz", "default":
+		ver, err := osutil.ProductVersion()
+		if err == nil && ver.Major >= 26 {
+			if isRunningInAppBundle() {
+				return true
+			}
+			logrus.Debug("Skipping GUI on macOS 26+ (no app bundle; use --foreground with Lima.app or SSH)")
