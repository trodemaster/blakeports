+// macos27_dfu_install_darwin_arm64.go
+// macOS 27 beta DFU install workaround.
+//
+// VZMacOSInstaller is broken when the guest IPSW is newer than the host OS.
+// needsDFUInstall detects this case; dfuInstallMacOS handles the install via
+// MobileDevice.framework DFU restore instead.
+//
+// TODO: Remove this file (and the companion .m/.h) once Apple fixes VZMacOSInstaller.
+
+//go:build darwin && arm64 && !no_vz
+
+package vz
+
+/*
+#cgo CFLAGS: -mmacosx-version-min=13.0
+#cgo LDFLAGS: -framework Foundation -framework Virtualization
+
+#import "macos27_dfu_install_darwin_arm64.h"
+
+static void freeErrString(char *s) { free(s); }
+*/
+import "C"
+import (
+	"context"
+	"fmt"
+	"os"
+	"path/filepath"
+	"unsafe"
+
+	"github.com/docker/go-units"
+	"github.com/lima-vm/lima/v2/pkg/limatype"
+	"github.com/lima-vm/lima/v2/pkg/limatype/filenames"
+	"github.com/sirupsen/logrus"
+)
+
+func checkFileExists(path string) error {
+	_, err := os.Stat(path)
+	return err
+}
+
+// needsDFUInstall reports whether installing the IPSW at ipswPath requires the DFU path.
+// Returns true when the guest OS major version is greater than the host OS major version.
+func needsDFUInstall(ipswPath string) (bool, error) {
+	cIpsw := C.CString(ipswPath)
+	defer C.free(unsafe.Pointer(cIpsw))
+
+	guestMajor := int(C.ipswGuestMajorVersion(cIpsw))
+	if guestMajor <= 0 {
+		return false, fmt.Errorf("could not determine guest OS version from IPSW %s", filepath.Base(ipswPath))
+	}
+	hostMajor := int(C.hostMajorOSVersion())
+	logrus.Debugf("DFU install check: guest macOS %d, host macOS %d", guestMajor, hostMajor)
+	return guestMajor > hostMajor, nil
+}
+
+// dfuInstallMacOS installs macOS by booting the VM in DFU mode and using MobileDevice.framework
+// to drive the IPSW restore. The instance directory must already contain vz-identifier,
+// vz-hwmodel, and disk (vz-aux is created if absent).
+func dfuInstallMacOS(_ context.Context, inst *limatype.Instance, ipswPath string) error {
+	// Ensure required files exist before entering CGo.
+	for _, f := range []string{filenames.VzIdentifier, filenames.VzHwModel, filenames.Disk} {
+		p := filepath.Join(inst.Dir, f)
+		if err := checkFileExists(p); err != nil {
+			return fmt.Errorf("DFU install prerequisite missing: %w", err)
+		}
+	}
+
+	memBytes, err := units.RAMInBytes(*inst.Config.Memory)
+	if err != nil {
+		return fmt.Errorf("invalid memory size: %w", err)
+	}
+
+	cDir := C.CString(inst.Dir)
+	defer C.free(unsafe.Pointer(cDir))
+	cIpsw := C.CString(ipswPath)
+	defer C.free(unsafe.Pointer(cIpsw))
+
+	logrus.Infof("DFU install: starting (instDir=%s, ipsw=%s)", inst.Dir, filepath.Base(ipswPath))
+
+	cErr := C.dfuInstall(cDir, cIpsw, C.uint(uint(*inst.Config.CPUs)), C.ulonglong(uint64(memBytes)))
+	if cErr != nil {
+		defer C.freeErrString(cErr)
+		return fmt.Errorf("macOS DFU install failed: %s", C.GoString(cErr))
+	}
+	return nil
+}
