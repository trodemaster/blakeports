+
+	"github.com/lima-vm/lima/v2/pkg/limatype"
+)
+
+// cmpTCCEntry lets go-cmp compare the unexported fields of tccEntry.
+var cmpTCCEntry = cmp.AllowUnexported(tccEntry{})
+
+func TestBuildTCCEntries(t *testing.T) {
+	tests := []struct {
+		name    string
+		perms   []limatype.TCCPermission
+		want    []tccEntry
+		wantErr string
+	}{
+		{
+			name: "preset expands to multiple entries",
+			perms: []limatype.TCCPermission{
+				{Preset: "terminal-accessibility"},
+			},
+			want: tccPresets["terminal-accessibility"],
+		},
+		{
+			name: "unknown preset",
+			perms: []limatype.TCCPermission{
+				{Preset: "no-such-preset"},
+			},
+			wantErr: `unknown TCC preset "no-such-preset"`,
+		},
+		{
+			name: "custom path entry with default authValue",
+			perms: []limatype.TCCPermission{
+				{
+					Service:    "kTCCServiceAccessibility",
+					Client:     "/opt/local/bin/cliclick",
+					ClientType: "path",
+				},
+			},
+			want: []tccEntry{
+				{
+					service:     "kTCCServiceAccessibility",
+					client:      "/opt/local/bin/cliclick",
+					clientType:  1,
+					authValue:   2,
+					authVersion: 1,
+				},
+			},
+		},
+		{
+			name: "custom bundle entry with deny",
+			perms: []limatype.TCCPermission{
+				{
+					Service:    "kTCCServiceMicrophone",
+					Client:     "com.example.app",
+					ClientType: "bundle",
+					AuthValue:  "deny",
+				},
+			},
+			want: []tccEntry{
+				{
+					service:     "kTCCServiceMicrophone",
+					client:      "com.example.app",
+					clientType:  0,
+					authValue:   0,
+					authVersion: 1,
+				},
+			},
+		},
+		{
+			name: "invalid clientType",
+			perms: []limatype.TCCPermission{
+				{Service: "kTCCServiceAccessibility", Client: "x", ClientType: "pathy"},
+			},
+			wantErr: `clientType "pathy"`,
+		},
+		{
+			name: "invalid authValue",
+			perms: []limatype.TCCPermission{
+				{Service: "kTCCServiceAccessibility", Client: "x", ClientType: "path", AuthValue: "maybe"},
+			},
+			wantErr: `authValue "maybe"`,
+		},
+		{
+			name: "preset and custom entries combine in order",
+			perms: []limatype.TCCPermission{
+				{Preset: "sshd-full-disk-access"},
+				{
+					Service:    "kTCCServiceAccessibility",
+					Client:     "/opt/local/bin/cliclick",
+					ClientType: "path",
+					AuthValue:  "allow",
+				},
+			},
+			want: append(append([]tccEntry{}, tccPresets["sshd-full-disk-access"]...), tccEntry{
+				service:     "kTCCServiceAccessibility",
+				client:      "/opt/local/bin/cliclick",
+				clientType:  1,
+				authValue:   2,
+				authVersion: 1,
+			}),
+		},
+	}
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got, err := buildTCCEntries(tt.perms)
+			if tt.wantErr != "" {
+				assert.ErrorContains(t, err, tt.wantErr)
+				return
+			}
+			assert.NilError(t, err)
+			assert.DeepEqual(t, got, tt.want, cmpTCCEntry)
+		})
+	}
+}
+
+func TestSQLQuote(t *testing.T) {
+	assert.Equal(t, sqlQuote("plain"), "'plain'")
+	assert.Equal(t, sqlQuote("it's"), "'it''s'")
+	assert.Equal(t, sqlQuote(""), "''")
+	assert.Equal(t, sqlQuote("a'b'c"), "'a''b''c'")
+}
+
+func TestBlobLiteral(t *testing.T) {
+	assert.Equal(t, blobLiteral(nil), "NULL")
+	assert.Equal(t, blobLiteral([]byte{}), "NULL")
+	assert.Equal(t, blobLiteral([]byte{0xfa, 0xde, 0x0c, 0x00}), "X'fade0c00'")
+}
+
+func TestMkdirAllTracked(t *testing.T) {
+	base := t.TempDir()
+
+	// All components created from scratch are reported.
+	created, err := mkdirAllTracked(base, "a/b/c")
+	assert.NilError(t, err)
+	assert.DeepEqual(t, created, []string{"a", filepath.Join("a", "b"), filepath.Join("a", "b", "c")})
+
+	// Pre-existing components are not reported again.
+	created, err = mkdirAllTracked(base, "a/b/d")
+	assert.NilError(t, err)
+	assert.DeepEqual(t, created, []string{filepath.Join("a", "b", "d")})
+
+	// Fully existing path reports nothing.
+	created, err = mkdirAllTracked(base, "a/b/c")
+	assert.NilError(t, err)
+	assert.Assert(t, created == nil)
+}
+
+// TestWriteTCCDatabase writes entries into a fresh database in a temp
+// directory and reads them back with sqlite3 to verify the row contents.
+func TestWriteTCCDatabase(t *testing.T) {
+	if _, err := exec.LookPath("sqlite3"); err != nil {
+		t.Skip("sqlite3 not found in PATH")
+	}
+	ctx := t.Context()
+	base := t.TempDir()
+	relDir := "Library/Application Support/com.apple.TCC"
+
+	entries, err := buildTCCEntries([]limatype.TCCPermission{
+		{Preset: "sshd-full-disk-access"},
+		{
+			Service:    "kTCCServiceAccessibility",
+			Client:     "/opt/local/bin/cliclick",
+			ClientType: "path",
+		},
+	})
+	assert.NilError(t, err)
+
+	created, err := writeTCCDatabase(ctx, base, relDir, entries)
+	assert.NilError(t, err)
+
+	// The DB file itself must be in the created list so the caller chowns it.
+	dbRel := filepath.Join(relDir, "TCC.db")
+	assert.Assert(t, slices.Contains(created, dbRel), "created=%v should contain %q", created, dbRel)
+
+	dbPath := filepath.Join(base, dbRel)
+	_, err = os.Stat(dbPath)
+	assert.NilError(t, err)
+
+	query := func(sql string) string {
+		out, err := exec.CommandContext(ctx, "sqlite3", dbPath, sql).CombinedOutput()
+		assert.NilError(t, err, "sqlite3 query failed: %s", out)
+		return strings.TrimSpace(string(out))
+	}
+
+	// Schema version must be stamped for tccd migration.
+	assert.Equal(t, query(`SELECT value FROM admin WHERE key='version';`), "30")
+
+	// Preset row: csreq blob present, allow, admin/system reason.
+	assert.Equal(t,
+		query(`SELECT client_type, auth_value, auth_reason, csreq IS NOT NULL
+		       FROM access WHERE service='kTCCServiceSystemPolicyAllFiles'
+		       AND client='/usr/libexec/sshd-keygen-wrapper';`),
+		"1|2|4|1")
+
+	// Custom row: no csreq, allow.
+	assert.Equal(t,
+		query(`SELECT client_type, auth_value, auth_reason, csreq IS NULL
+		       FROM access WHERE service='kTCCServiceAccessibility'
+		       AND client='/opt/local/bin/cliclick';`),
+		"1|2|4|1")
+
+	// Re-running is idempotent (INSERT OR REPLACE, CREATE IF NOT EXISTS).
+	_, err = writeTCCDatabase(ctx, base, relDir, entries)
+	assert.NilError(t, err)
+	assert.Equal(t, query(`SELECT COUNT(*) FROM access;`), "2")
+}
