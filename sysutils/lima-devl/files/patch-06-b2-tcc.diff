diff --git a/pkg/guestpatch/macos/tcc_darwin.go b/pkg/guestpatch/macos/tcc_darwin.go
new file mode 100644
index 00000000..717f4719
--- /dev/null
+++ b/pkg/guestpatch/macos/tcc_darwin.go
@@ -0,0 +1,401 @@
+// SPDX-FileCopyrightText: Copyright The Lima Authors
+// SPDX-License-Identifier: Apache-2.0
+
+package macos
+
+import (
+	"context"
+	"encoding/hex"
+	"fmt"
+	"os"
+	"os/exec"
+	"path/filepath"
+	"strings"
+
+	"github.com/lima-vm/lima/v2/pkg/limatype"
+)
+
+type tccEntry struct {
+	service                      string
+	client                       string
+	clientType                   int    // 0=bundle, 1=path
+	authValue                    int    // 0=deny, 2=allow
+	authReason                   int    // 0=use default (4); 3=user-set; 4=admin/system
+	authVersion                  int    // usually 1; kTCCServicePostEvent uses 2
+	csreq                        []byte // nil = no csreq (skips code-signing check)
+	indirectObjectIdentifier     string // "" means use "UNUSED"; for AppleEvents: bundle/path of receiver
+	indirectObjectIdentifierType int    // 0=bundle, 1=path
+	indirectObjectCodeIdentity   []byte // csreq of receiver app; nil = NULL
+	userLevel                    bool   // true = write to per-user TCC DB, false = system TCC DB
+}
+
+// csreq blobs generated via:
+//
+//	echo 'identifier "…" and anchor apple' | csreq -b /tmp/out.csreq -r - && xxd -p /tmp/out.csreq
+//
+// Verified against live macOS 15 VM TCC databases.
+// Identifier+AppleAnchor requirements are stable for Apple-signed system binaries.
+var (
+	csreqTerminal = mustDecodeHex(
+		"fade0c000000003000000001000000060000000200000012" +
+			"636f6d2e6170706c652e5465726d696e616c000000000003")
+	csreqSSHDKeygen = mustDecodeHex(
+		"fade0c000000003c0000000100000006000000020000001d" +
+			"636f6d2e6170706c652e737368642d6b657967656e2d777261707065720000000000000003")
+	// Receiver csreq blobs for AppleEvents presets.
+	// Genuine user-consent rows include the receiver's code-signing requirement;
+	// omitting it (NULL) caused tccd to delete the entries on first boot (dev.9).
+	csreqFinder = mustDecodeHex(
+		"fade0c000000002c00000001000000060000000200000010" +
+			"636f6d2e6170706c652e66696e64657200000003")
+	csreqSystemEvents = mustDecodeHex(
+		"fade0c000000003400000001000000060000000200000016" +
+			"636f6d2e6170706c652e73797374656d6576656e7473000000000003")
+)
+
+func mustDecodeHex(s string) []byte {
+	b, err := hex.DecodeString(s)
+	if err != nil {
+		panic("invalid csreq hex literal: " + err.Error())
+	}
+	return b
+}
+
+// tccPresets maps preset name → one or more TCC entries to insert.
+// System-level entries (userLevel=false) go into /Library/Application Support/com.apple.TCC/TCC.db.
+// User-level entries (userLevel=true) go into ~/Library/Application Support/com.apple.TCC/TCC.db.
+// Captured from macOS 15 after manually granting each permission.
+var tccPresets = map[string][]tccEntry{
+	// sshd-full-disk-access: allows the SSH daemon to read any file on the system.
+	"sshd-full-disk-access": {
+		{
+			service:     "kTCCServiceSystemPolicyAllFiles",
+			client:      "/usr/libexec/sshd-keygen-wrapper",
+			clientType:  1,
+			authValue:   2,
+			authVersion: 1,
+			csreq:       csreqSSHDKeygen,
+		},
+	},
+	// lima-guestagent-full-disk-access: allows the lima guest agent to read any file.
+	// The agent binary is on the cidata volume at /Volumes/cidata/lima-guestagent.
+	// csreq is nil (NULL) because the binary is rebuilt per-release; NULL skips
+	// code-signing validation for this path-based entry.
+	"lima-guestagent-full-disk-access": {
+		{
+			service:     "kTCCServiceSystemPolicyAllFiles",
+			client:      "/Volumes/cidata/lima-guestagent",
+			clientType:  1,
+			authValue:   2,
+			authVersion: 1,
+			csreq:       nil,
+		},
+	},
+	// terminal-accessibility: allows Terminal to control the Mac via Accessibility APIs
+	// and to post synthetic keyboard/mouse events. Both rows are required.
+	"terminal-accessibility": {
+		{
+			service:     "kTCCServiceAccessibility",
+			client:      "com.apple.Terminal",
+			clientType:  0,
+			authValue:   2,
+			authVersion: 1,
+			csreq:       csreqTerminal,
+		},
+		{
+			service:     "kTCCServicePostEvent",
+			client:      "com.apple.Terminal",
+			clientType:  0,
+			authValue:   2,
+			authVersion: 2,
+			csreq:       csreqTerminal,
+		},
+	},
+	// terminal-apple-events: allows Terminal to send AppleEvents to System Events,
+	// enabling AppleScript/UI automation from Terminal windows and .command scripts.
+	// Written into the system TCC DB with auth_reason=4 (system policy).
+	// indirect_object_code_identity carries the System Events csreq — genuine user-consent
+	// rows always populate this field; omitting it (dev.9, NULL) caused tccd to delete
+	// the entries on first boot.
+	"terminal-apple-events": {
+		{
+			service:                      "kTCCServiceAppleEvents",
+			client:                       "com.apple.Terminal",
+			clientType:                   0,
+			authValue:                    2,
+			authVersion:                  1,
+			csreq:                        csreqTerminal,
+			indirectObjectIdentifier:     "com.apple.systemevents",
+			indirectObjectIdentifierType: 0,
+			indirectObjectCodeIdentity:   csreqSystemEvents,
+		},
+	},
+	// sshd-apple-events-finder: allows the SSH daemon to send AppleEvents to Finder.
+	// Required for SSH-based automation (e.g. setting wallpaper via osascript).
+	// indirect_object_code_identity carries the Finder csreq — same rationale as
+	// terminal-apple-events above.
+	"sshd-apple-events-finder": {
+		{
+			service:                      "kTCCServiceAppleEvents",
+			client:                       "/usr/libexec/sshd-keygen-wrapper",
+			clientType:                   1,
+			authValue:                    2,
+			authVersion:                  1,
+			csreq:                        csreqSSHDKeygen,
+			indirectObjectIdentifier:     "com.apple.finder",
+			indirectObjectIdentifierType: 0,
+			indirectObjectCodeIdentity:   csreqFinder,
+		},
+	},
+}
+
+// patchTCC writes TCC permission entries into the system and per-user TCC databases
+// on the mounted guest disk. It creates directory structures as needed and returns
+// the relative paths of newly created entries split by ownership:
+//   - rootPaths: owned by root:wheel (system TCC database files)
+//   - userPaths: owned by the guest user (user TCC database files)
+func patchTCC(ctx context.Context, mnt, guestHomeRelDir string, perms []limatype.TCCPermission) (rootPaths, userPaths []string, err error) {
+	if len(perms) == 0 {
+		return nil, nil, nil
+	}
+
+	var systemEntries, userEntries []tccEntry
+	for _, p := range perms {
+		if p.Preset != "" {
+			preset, ok := tccPresets[p.Preset]
+			if !ok {
+				return nil, nil, fmt.Errorf("unknown TCC preset %q; available: %s",
+					p.Preset, availablePresets())
+			}
+			for _, e := range preset {
+				if e.userLevel {
+					userEntries = append(userEntries, e)
+				} else {
+					systemEntries = append(systemEntries, e)
+				}
+			}
+			continue
+		}
+		e := tccEntry{service: p.Service, client: p.Client}
+		switch p.ClientType {
+		case "bundle":
+			e.clientType = 0
+		case "path":
+			e.clientType = 1
+		default:
+			return nil, nil, fmt.Errorf("tccPermission clientType %q: expected \"bundle\" or \"path\"", p.ClientType)
+		}
+		switch p.AuthValue {
+		case "allow", "":
+			e.authValue = 2
+		case "deny":
+			e.authValue = 0
+		default:
+			return nil, nil, fmt.Errorf("tccPermission authValue %q: expected \"allow\" or \"deny\"", p.AuthValue)
+		}
+		e.authVersion = 1
+		if p.Receiver != "" {
+			e.indirectObjectIdentifier = p.Receiver
+			switch p.ReceiverType {
+			case "bundle", "":
+				e.indirectObjectIdentifierType = 0
+			case "path":
+				e.indirectObjectIdentifierType = 1
+			default:
+				return nil, nil, fmt.Errorf("tccPermission receiverType %q: expected \"bundle\" or \"path\"", p.ReceiverType)
+			}
+			e.userLevel = true
+		}
+		if e.userLevel {
+			userEntries = append(userEntries, e)
+		} else {
+			systemEntries = append(systemEntries, e)
+		}
+	}
+
+	if len(systemEntries) > 0 {
+		rp, err := writeTCCDatabase(ctx, mnt, "Library/Application Support/com.apple.TCC", systemEntries)
+		if err != nil {
+			return nil, nil, fmt.Errorf("system TCC: %w", err)
+		}
+		rootPaths = append(rootPaths, rp...)
+	}
+
+	if len(userEntries) > 0 && guestHomeRelDir != "" {
+		up, err := writeTCCDatabase(ctx, mnt,
+			filepath.Join(guestHomeRelDir, "Library", "Application Support", "com.apple.TCC"),
+			userEntries)
+		if err != nil {
+			return nil, nil, fmt.Errorf("user TCC: %w", err)
+		}
+		userPaths = append(userPaths, up...)
+	}
+
+	return rootPaths, userPaths, nil
+}
+
+// writeTCCDatabase creates (if needed) the TCC directory at relDir under mnt,
+// initialises the database schema, inserts all entries, and returns the relative
+// paths of any newly created filesystem entries.
+func writeTCCDatabase(ctx context.Context, mnt, relDir string, entries []tccEntry) ([]string, error) {
+	created, err := mkdirAllTracked(mnt, relDir)
+	if err != nil {
+		return nil, fmt.Errorf("failed to create TCC directory %q: %w", relDir, err)
+	}
+
+	dbPath := filepath.Join(mnt, relDir, "TCC.db")
+
+	schema := `
+CREATE TABLE IF NOT EXISTS admin (
+    key   TEXT PRIMARY KEY NOT NULL,
+    value INTEGER NOT NULL
+);
+INSERT OR REPLACE INTO admin VALUES ('version', 30);
+CREATE TABLE IF NOT EXISTS policies (
+    id        INTEGER NOT NULL PRIMARY KEY,
+    bundle_id TEXT    NOT NULL,
+    uuid      TEXT    NOT NULL,
+    display   TEXT    NOT NULL,
+    UNIQUE (bundle_id, uuid)
+);
+CREATE TABLE IF NOT EXISTS active_policy (
+    client      TEXT    NOT NULL,
+    client_type INTEGER NOT NULL,
+    policy_id   INTEGER NOT NULL,
+    PRIMARY KEY (client, client_type),
+    FOREIGN KEY (policy_id) REFERENCES policies(id) ON DELETE CASCADE ON UPDATE CASCADE
+);
+CREATE INDEX IF NOT EXISTS active_policy_id ON active_policy(policy_id);
+CREATE TABLE IF NOT EXISTS access (
+    service                            TEXT    NOT NULL,
+    client                             TEXT    NOT NULL,
+    client_type                        INTEGER NOT NULL,
+    auth_value                         INTEGER NOT NULL,
+    auth_reason                        INTEGER NOT NULL,
+    auth_version                       INTEGER NOT NULL,
+    csreq                              BLOB,
+    policy_id                          INTEGER,
+    indirect_object_identifier_type    INTEGER,
+    indirect_object_identifier         TEXT    NOT NULL DEFAULT 'UNUSED',
+    indirect_object_code_identity      BLOB,
+    flags                              INTEGER,
+    last_modified                      INTEGER NOT NULL DEFAULT (CAST(strftime('%s','now') AS INTEGER)),
+    pid                                INTEGER,
+    pid_version                        INTEGER,
+    boot_uuid                          TEXT    NOT NULL DEFAULT 'UNUSED',
+    last_reminded                      INTEGER NOT NULL DEFAULT (CAST(strftime('%s','now') AS INTEGER)),
+    PRIMARY KEY (service, client, client_type, indirect_object_identifier),
+    FOREIGN KEY (policy_id) REFERENCES policies(id) ON DELETE CASCADE ON UPDATE CASCADE
+);
+CREATE TABLE IF NOT EXISTS access_overrides (service TEXT NOT NULL PRIMARY KEY);
+CREATE TABLE IF NOT EXISTS expired (
+    service       TEXT    NOT NULL,
+    client        TEXT    NOT NULL,
+    client_type   INTEGER NOT NULL,
+    csreq         BLOB,
+    last_modified INTEGER NOT NULL,
+    expired_at    INTEGER NOT NULL DEFAULT (CAST(strftime('%s','now') AS INTEGER)),
+    PRIMARY KEY (service, client, client_type)
+);`
+	if err := runSQLite(ctx, dbPath, schema); err != nil {
+		return nil, fmt.Errorf("failed to initialize TCC schema: %w", err)
+	}
+
+	for _, e := range entries {
+		if err := insertTCCEntry(ctx, dbPath, e); err != nil {
+			return nil, err
+		}
+	}
+
+	return append(created, filepath.Join(relDir, "TCC.db")), nil
+}
+
+// insertTCCEntry inserts or replaces one row in the TCC access table.
+func insertTCCEntry(ctx context.Context, dbPath string, e tccEntry) error {
+	csreqLit := blobLiteral(e.csreq)
+
+	indirectID := "UNUSED"
+	if e.indirectObjectIdentifier != "" {
+		indirectID = e.indirectObjectIdentifier
+	}
+	recvCsreqLit := blobLiteral(e.indirectObjectCodeIdentity)
+
+	authReason := e.authReason
+	if authReason == 0 {
+		authReason = 4 // default: admin/system set
+	}
+
+	sql := fmt.Sprintf(
+		`INSERT OR REPLACE INTO access
+		 (service, client, client_type, auth_value, auth_reason, auth_version,
+		  csreq, indirect_object_identifier_type, indirect_object_identifier,
+		  indirect_object_code_identity, boot_uuid, last_reminded)
+		 VALUES (%s, %s, %d, %d, %d, %d,
+		         %s, %d, %s,
+		         %s, 'UNUSED', CAST(strftime('%%s','now') AS INTEGER));`,
+		sqlQuote(e.service), sqlQuote(e.client),
+		e.clientType, e.authValue, authReason, e.authVersion,
+		csreqLit,
+		e.indirectObjectIdentifierType, sqlQuote(indirectID),
+		recvCsreqLit,
+	)
+	return runSQLite(ctx, dbPath, sql)
+}
+
+// blobLiteral returns an SQLite X'hex' literal for b, or "NULL" if b is empty.
+func blobLiteral(b []byte) string {
+	if len(b) == 0 {
+		return "NULL"
+	}
+	return "X'" + hex.EncodeToString(b) + "'"
+}
+
+// mkdirAllTracked creates each component of relPath under base one at a time,
+// returning the relative paths of directories that did not already exist
+// (and were therefore written through the noowners mount with UID=99).
+func mkdirAllTracked(base, relPath string) ([]string, error) {
+	parts := strings.Split(relPath, string(filepath.Separator))
+	var created []string
+	current := ""
+	for _, part := range parts {
+		if part == "" {
+			continue
+		}
+		if current == "" {
+			current = part
+		} else {
+			current = filepath.Join(current, part)
+		}
+		abs := filepath.Join(base, current)
+		if _, err := os.Stat(abs); os.IsNotExist(err) {
+			if err := os.Mkdir(abs, 0o755); err != nil {
+				return nil, err
+			}
+			created = append(created, current)
+		}
+	}
+	return created, nil
+}
+
+// runSQLite executes sql against dbPath using the system sqlite3 binary.
+func runSQLite(ctx context.Context, dbPath, sql string) error {
+	cmd := exec.CommandContext(ctx, "sqlite3", dbPath, sql)
+	out, err := cmd.CombinedOutput()
+	if err != nil {
+		return fmt.Errorf("sqlite3: %w: %s", err, strings.TrimSpace(string(out)))
+	}
+	return nil
+}
+
+// sqlQuote wraps s in single quotes, escaping embedded single quotes.
+func sqlQuote(s string) string {
+	return "'" + strings.ReplaceAll(s, "'", "''") + "'"
+}
+
+func availablePresets() string {
+	names := make([]string, 0, len(tccPresets))
+	for k := range tccPresets {
+		names = append(names, k)
+	}
+	return strings.Join(names, ", ")
+}
