+
+package main
+
+import "runtime"
+
+func init() {
+	// Pin the main goroutine to OS thread 0 before main() runs.
+	// VZVirtualMachineView requires GUI operations on the process main thread;
+	// without this, Go's scheduler may migrate it before hostagent starts.
+	runtime.LockOSThread()
+}
