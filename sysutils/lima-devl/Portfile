go.setup            github.com/lima-vm/lima 4d1c1b2ae24e19c02bfce8e8e2960255cd724b65
version             2.1.3-dev.20260627
go.offline_build    no
name                lima-devl
revision            0

homepage            https://lima-vm.io

# Patch revisions — increment when a patch is regenerated against new upstream
set g3_rev  13
set b1_rev  16
set b2_rev  11
set b3_rev  6
set m1_rev  1

description         Lima ${version} | G3:r${g3_rev} B1:r${b1_rev} B2:r${b2_rev} B3:r${b3_rev} M1:r${m1_rev} | off: O1 (G1 upstream, G4 upstream)

long_description    {*}${description}

categories          sysutils
installs_libs       no
license             Apache-2
maintainers         {@trodemaster icloud.com:manuals-unread2u} \
                    openmaintainer

conflicts           lima

checksums           rmd160  09a958bcbdec9855f1a60079a4c5e05b938d525f \
                    sha256  618397da27a9effce144802c828c156cf241b177fb98e414b423a2e566e68866 \
                    size    7817520

# Standard patches (shared with the upstream lima port)
# Feature patches (upstream PR candidates, applied in dependency order)
# macOS 27 workarounds applied last — NOT for upstream submission
patchfiles          patch-Makefile.diff \
                    patch-usrlocalgo.diff \
                    patch-04-g3-screenshot.diff \
                    patch-05-b1-fakecloudinit.diff \
                    patch-06-b2-tcc.diff \
                    patch-09-m1-fakecloudinit-macos27.diff \
                    patch-08-b3-dfu-beta27.diff
#                     \
#                    patch-07-o1-pid-timeout.diff

build.cmd           make
build.args-append   native

platform darwin {
    # Lima defaults to VZ with macOS 13.5 and later; drop dependency from 14 onwards
    if {${os.major} < 23} {
        depends_run-append port:qemu
    }
}

variant additional_guestagents description {Guest agents for all architectures} {
  build.args-append  additional-guestagents
  depends_run-append port:qemu
}

post-patch {
    reinplace "s|@@VERSION@@|${version}|g" ${worksrcpath}/Makefile
}

post-build {
    set limactl ${worksrcpath}/_output/bin/limactl

    set bash_completions_dir ${worksrcpath}/_output/share/bash-completion/completions
    set fish_completions_dir ${worksrcpath}/_output/share/fish/vendor_completions.d
    set zsh_completions_dir ${worksrcpath}/_output/share/zsh/site-functions

    xinstall -d ${bash_completions_dir} ${fish_completions_dir} ${zsh_completions_dir}

    system "${limactl} completion bash > ${bash_completions_dir}/${name}"
    system "${limactl} completion fish > ${fish_completions_dir}/${name}.fish"
    system "${limactl} completion zsh > ${zsh_completions_dir}/_${name}"
}

destroot {
    system -W ${worksrcpath} "make install DEST=${destroot}${prefix}"
}

notes {
    Lima has a variant (+additional_guestagents, disabled by default),\
    that builds guest agents for all supported architectures, requiring\
    qemu.
}

github.livecheck.regex {([0-9.]+)}
