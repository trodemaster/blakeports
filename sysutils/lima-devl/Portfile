# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           golang 1.0

go.setup            github.com/lima-vm/lima 2.1.1 v
go.offline_build    no
name                lima-devl
revision            0

homepage            https://lima-vm.io

description         Linux virtual machines (with macOS GUI and TCC extensions)

long_description    {*}{
    Lima launches Linux virtual machines with automatic file sharing
    and port forwarding (similar to WSL2). The original goal of Lima
    was to promote containerd including nerdctl (contaiNERD ctl) to
    Mac users, but Lima can be used for non-container applications as
    well. Lima also supports other container engines, such as Docker,
    Podman, Kubernetes, etc. Lima can also emulate other architectures
    if QEMU is installed.

    This port applies experimental patches on top of upstream Lima
    that are pending upstream review:
    - macOS app bundle (Lima.app) for VZ GUI display on macOS 26+
    - limactl screenshot command for VZ GUI VMs
    - fakecloudinit: suppress macOS guest first-run setup screens
    - guestpatch: pre-populate TCC database during disk patching
    - hostagent PID wait timeout increase for macOS 26+
}

categories          sysutils
installs_libs       no
license             Apache-2
maintainers         {@trodemaster icloud.com:manuals-unread2u} \
                    openmaintainer

conflicts           lima

checksums           rmd160  b01c90ce75e3a08433f11852b224ea8b1cc56299 \
                    sha256  c1cb9f2a5d35715937bbf21566d58f89fc221ab285a42ddcc30fd6fdaab2c15a \
                    size    7795047

# Standard patches (shared with the upstream lima port)
# Feature patches (upstream PR candidates, applied in dependency order)
patchfiles          patch-Makefile.diff \
                    patch-usrlocalgo.diff \
                    patch-01-g1-thread-pin.diff \
                    patch-02-g2-app-bundle.diff \
                    patch-03-g2-macports-applications-path.diff \
                    patch-04-g3-screenshot.diff \
                    patch-05-b1-fakecloudinit.diff \
                    patch-06-b2-tcc.diff \
                    patch-07-o1-pid-timeout.diff

build.cmd           make
# APP_BUNDLE_DIR controls where Lima.app is built within _output/
# (enabled by patch-02-g2-app-bundle.diff which adds the Makefile target)
build.args-append   native \
                    APP_BUNDLE_DIR=_output/share/lima

platform darwin {
    # Lima defaults to VZ with macOS 13.5 and later; drop dependency from 14 onwards
    if {${os.major} < 23} {
        depends_run-append port:qemu
    }
}

variant additional_guestagents description {Guest agents for all architectures} {
  build.args-append  additional-guestagents
  depends_run-append port:qemu
}

post-patch {
    reinplace "s|@@VERSION@@|${version}|g" ${worksrcpath}/Makefile
}

post-build {
    set limactl ${worksrcpath}/_output/bin/limactl

    set bash_completions_dir ${worksrcpath}/_output/share/bash-completion/completions
    set fish_completions_dir ${worksrcpath}/_output/share/fish/vendor_completions.d
    set zsh_completions_dir ${worksrcpath}/_output/share/zsh/site-functions

    xinstall -d ${bash_completions_dir} ${fish_completions_dir} ${zsh_completions_dir}

    system "${limactl} completion bash > ${bash_completions_dir}/${name}"
    system "${limactl} completion fish > ${fish_completions_dir}/${name}.fish"
    system "${limactl} completion zsh > ${zsh_completions_dir}/_${name}"
}

destroot {
    system -W ${worksrcpath} "make install DEST=${destroot}${prefix}"

    # Install Lima.app to the standard MacPorts Applications directory
    # so it appears alongside other MacPorts GUI apps at /Applications/MacPorts/
    platform darwin {
        xinstall -d ${destroot}/Applications/MacPorts
        file rename \
            ${destroot}${prefix}/share/lima/Lima.app \
            ${destroot}/Applications/MacPorts/Lima.app
    }
}

notes {
    Lima has a variant (+additional_guestagents, disabled by default),\
    that builds guest agents for all supported architectures, requiring\
    qemu.

    This build includes an experimental macOS app bundle (Lima.app) for\
    GUI display on macOS 26+. When starting a VM with video.display=default\
    on macOS 26+, the hostagent launches inside Lima.app for proper Window\
    Server context.

    The guestpatch TCC feature adds a tccPermissions key to lima.yaml.\
    Instances configured with tccPermissions are not compatible with the\
    upstream lima port — remove the key before switching.
}

github.livecheck.regex {([0-9.]+)}
