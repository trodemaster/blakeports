# macports-cache — local MacPorts binary archive cache server
#
# Persistent configuration overrides go in config.mk (git-ignored):
#   PORT      = 9000
#   CACHE_DIR = /Volumes/MyDisk/macports-cache
-include config.mk

PORT      ?= 8030
CACHE_DIR ?= $(HOME)/Library/Caches/macports-cache
MOUNT     ?= /Volumes/macports-cache

# Binary is installed by go install — path derived from go env, not configurable.
_gobin := $(or $(shell GOWORK=off go env GOBIN),$(shell GOWORK=off go env GOPATH)/bin)
BIN    := $(_gobin)/macports-cache
LABEL  := com.blakeports.macports-cache
PLIST := $(HOME)/Library/LaunchAgents/$(LABEL).plist
LOG   := $(HOME)/Library/Logs/macports-cache.log

SHELL := /bin/bash

.PHONY: all build install uninstall reinstall start stop restart \
        status logs clean submit setup-client config help _plist

all: build

build: ## Compile the server binary
	GOWORK=off go build -o macports-cache .

install: ## Install binary via go install, write launchd agent, start server
	GOWORK=off go install .
	mkdir -p $(CACHE_DIR) $(HOME)/Library/LaunchAgents $(HOME)/Library/Logs
	$(MAKE) _plist
	-launchctl bootout gui/$$(id -u) $(PLIST) 2>/dev/null; true
	launchctl bootstrap gui/$$(id -u) $(PLIST)
	@echo ""
	@echo "macports-cache running on port $(PORT)"
	@echo "  cache:  $(CACHE_DIR)"
	@echo "  binary: $(BIN)"
	@echo "  log:    $(LOG)"
	@echo ""
	@echo "Next: share $(CACHE_DIR) via File Sharing, then run:"
	@echo "  make setup-client HOST=<this-machine>"

reinstall: ## Reinstall via go install, rewrite plist, reload (cache data untouched)
	GOWORK=off go install .
	$(MAKE) _plist
	-launchctl bootout gui/$$(id -u) $(PLIST) 2>/dev/null; true
	launchctl bootstrap gui/$$(id -u) $(PLIST)
	@echo "reloaded"

uninstall: stop ## Stop and remove binary + launchd agent (cache data untouched)
	rm -f $(BIN) $(PLIST)
	@echo "uninstalled — cache data in $(CACHE_DIR) is untouched"
	@echo "To also remove cache data: rm -rf $(CACHE_DIR)"

start: ## Start the launchd agent
	launchctl bootstrap gui/$$(id -u) $(PLIST)

stop: ## Stop the launchd agent
	-launchctl bootout gui/$$(id -u) $(PLIST) 2>/dev/null; true

restart: stop start ## Restart the launchd agent

status: ## Show launchd status and server health
	@echo "==> launchd ($(LABEL)):"
	@launchctl print gui/$$(id -u)/$(LABEL) 2>/dev/null | grep -E 'state|pid|path|program' || echo "  not loaded"
	@echo ""
	@echo "==> server (http://localhost:$(PORT)):"
	@curl -sf http://localhost:$(PORT)/status 2>/dev/null || echo "  not responding"

logs: ## Tail the server log
	tail -f $(LOG)

clean: ## Remove the compiled binary (cache data and config untouched)
	rm -f macports-cache

# ── cache operations ──────────────────────────────────────────────────────────

submit: ## Submit a built port to the cache via mount  [PORTNAME=xxx] [MOUNT=path]
	@test -n "$(PORTNAME)" || { \
		echo "Usage: make submit PORTNAME=<portname> [MOUNT=<path>]"; \
		echo "       MOUNT defaults to $(MOUNT)"; \
		exit 1; }
	./scripts/submit-archive.sh "$(PORTNAME)" "$(MOUNT)"

setup-client: ## Configure a MacPorts machine to use this cache  [HOST=xxx] [PORT=8030]
	@test -n "$(HOST)" || { \
		echo "Usage: make setup-client HOST=<hostname> [PORT=<port>]"; \
		exit 1; }
	sudo ./scripts/setup-client.sh "$(HOST)" "$(PORT)"

config: ## Write config.mk with current effective values (edit to customise)
	@( \
		echo '# macports-cache local configuration — generated by: make config'; \
		echo '# Edit values here, then run: make reinstall'; \
		echo ''; \
		echo '# HTTP port the server listens on'; \
		echo 'PORT      = $(PORT)'; \
		echo ''; \
		echo '# Directory that holds archives and the signing keypair'; \
		echo '# Share this directory via File Sharing so build machines can submit'; \
		echo 'CACHE_DIR = $(CACHE_DIR)'; \
		echo ''; \
		echo '# Default file-share mount path used by: make submit'; \
		echo 'MOUNT     = $(MOUNT)'; \
	) | tee config.mk
	@echo ""
	@echo "wrote config.mk"

# ── internal ──────────────────────────────────────────────────────────────────

# Write the launchd plist with current variable values baked in.
# Re-run via 'make reinstall' if PORT or CACHE_DIR change.
_plist:
	@( \
		echo '<?xml version="1.0" encoding="UTF-8"?>'; \
		echo '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">'; \
		echo '<plist version="1.0">'; \
		echo '<dict>'; \
		echo '    <key>Label</key>'; \
		echo '    <string>$(LABEL)</string>'; \
		echo '    <key>ProgramArguments</key>'; \
		echo '    <array>'; \
		echo '        <string>$(BIN)</string>'; \
		echo '        <string>-port</string>'; \
		echo '        <string>$(PORT)</string>'; \
		echo '        <string>-dir</string>'; \
		echo '        <string>$(CACHE_DIR)</string>'; \
		echo '    </array>'; \
		echo '    <key>RunAtLoad</key>'; \
		echo '    <true/>'; \
		echo '    <key>KeepAlive</key>'; \
		echo '    <true/>'; \
		echo '    <key>StandardOutPath</key>'; \
		echo '    <string>$(LOG)</string>'; \
		echo '    <key>StandardErrorPath</key>'; \
		echo '    <string>$(LOG)</string>'; \
		echo '</dict>'; \
		echo '</plist>'; \
	) > $(PLIST)
	@echo "wrote $(PLIST)"

help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*##' Makefile | \
		awk 'BEGIN{FS=":.*## "} {printf "  \033[36m%-18s\033[0m %s\n", $$1, $$2}'
