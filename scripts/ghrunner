#!/usr/bin/env bash

# GitHub Actions Self-Hosted Runner Manager
# Supports lima (macOS) and vmware runners

#set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
RUNNER_TYPE=""
RUNNER_NAME=""
SSH_HOST=""
ACTION=""
RUNNER_TOKEN=""
DEBUG_MODE=""

# GitHub repository settings (can be overridden with command line options)
GITHUB_OWNER="${GITHUB_OWNER:-trodemaster}"
GITHUB_REPO="${GITHUB_REPO:-blakeports}"

# Default runner configuration (can be overridden with RUNNER_CONFIG env var)
# JSON format with type, name, ssh_host, and optional labels/description
DEFAULT_RUNNER_CONFIG='[
  {"type":"lima","name":"macos-26","ssh_host":""},
  {"type":"lima","name":"macos-26-beta","ssh_host":""},
  {"type":"lima","name":"macos-15","ssh_host":""},
  {"type":"vmware","name":"tenfive","ssh_host":""},
  {"type":"vmware","name":"tensix","ssh_host":""},
  {"type":"vmware","name":"tenseven","ssh_host":""},
  {"type":"vmware","name":"teneight","ssh_host":""},
  {"type":"vmware","name":"tennine","ssh_host":""},
  {"type":"vmware","name":"tenten","ssh_host":""},
  {"type":"vmware","name":"teneleven","ssh_host":""}
]'
RUNNER_CONFIG="${RUNNER_CONFIG:-$DEFAULT_RUNNER_CONFIG}"

# Tool paths
VMWARE_VMRUN_PATH="/Applications/VMware Fusion.app/Contents/Library/vmrun"
LIMACTL_PATH="/opt/local/bin/limactl"

# VMware configuration
VMWARE_SSH_HOST="darkstar"
VMWARE_BASE_DIR="/Volumes/JonesFarm/actions-runners"
VMWARE_VM_USER="blake"  # SSH user for VMware VMs

# Runner group configurations
LEGACY_RUNNERS=("tenfive" "tensix" "tenseven" "teneight" "tennine" "tenten" "teneleven")
CURRENT_RUNNERS=("macos-26" "macos-26-beta" "macos-15")
GROUP=""
STOP_VMS=""

# VMware Fusion REST API Configuration (darkstar)
# These should be exported by direnv from .envrc
VMWARE_REST_API_HOST="${VMWARE_REST_API_HOST}"
VMWARE_REST_API_PORT="${VMWARE_REST_API_PORT:-8697}"       # Default port if not set
VMWARE_REST_API_USER="${VMWARE_REST_API_USER}"
VMWARE_REST_API_PASS="${VMWARE_REST_API_PASS}"
VMWARE_REST_API_INSECURE="${VMWARE_REST_API_INSECURE:-true}"  # Use -k for self-signed certs

# SSH configuration
SSH_OPTS=(
    "-o" "ControlPath ~/.ssh/controlmasters/%r@%h:%p"
    "-o" "ControlMaster auto"
    "-o" "ControlPersist 10m"
    "-o" "StrictHostKeyChecking no"
    "-o" "UserKnownHostsFile=/dev/null"
    "-o" "IdentityAgent /Users/blake/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh"
)

# Legacy SSH configuration for old macOS VMs (10.5-10.10)
# These VMs require openssh9-client with legacy crypto algorithms
LEGACY_SSH_CMD="ssh9"
LEGACY_SSH_KEY="$HOME/.ssh/oldmac"
LEGACY_SSH_OPTS=(
    "-i" "$LEGACY_SSH_KEY"
    "-o" "HostKeyAlgorithms=ssh-rsa"
    "-o" "PubkeyAcceptedKeyTypes=ssh-rsa"
    "-o" "KexAlgorithms=diffie-hellman-group14-sha1,ecdh-sha2-nistp256,diffie-hellman-group1-sha1"
    "-o" "Ciphers=aes128-ctr,aes128-cbc"
    "-o" "MACs=hmac-sha1"
    "-o" "StrictHostKeyChecking=no"
    "-o" "Protocol=2"
)

# Function to print usage
usage() {
    cat << EOF
Usage: $0 [OPTIONS]

GitHub Actions Self-Hosted Runner Manager
Creates and manages different types of runners for the current repository.

Options:
    -lima <runner_name>     Create macOS runner using lima VM
    -vmware <runner_name>   Create VMware runner (stub)
    -ssh <hostname>         Use SSH to connect to remote host
    -owner <github_owner>   Override GitHub owner (default: trodemaster)
    -repo <repo_name>       Override repository name (default: blakeports)
    -list                   List currently registered runners for the repository
    -inspect-legacy-vms     Inspect available VMs on darkstar via REST API
    -start-all              Start all configured runners
    -start-group <group>    Start a group of runners (current|legacy|all)
    -stop-group <group>     Stop a group of runners (current|legacy|all)
    -stop-vms               Also stop VMware VMs when stopping legacy group
    -vmware-api-host <ip>   Override VMware REST API host
    -vmware-api-port <port> Override VMware REST API port
    -vmware-api-user <user> Override VMware REST API username
    -vmware-api-pass <pass> Override VMware REST API password
    -remove-all             Remove/de-register all GitHub runners
    -remove <runner_name>   Remove/de-register a GitHub runner
    -cancel-workflows       Cancel all running workflows
    -debug                  Enable debug mode for SSH connections
    -h, --help              Show this help message

Examples:
    # Register Lima macOS runners (instance must be running first)
    $0 -lima macos-26
    $0 -lima macos-26-beta
    $0 -lima macos-15

    # Create runner for specific owner/repo
    $0 -lima macos-26 -owner myusername -repo myproject

    # Manage runner groups
    $0 -start-group current    # Start lima runners (macos-26, macos-26-beta, macos-15)
    $0 -start-group legacy     # Start docker runners for legacy VMs
    $0 -start-group all        # Start all runners (current + legacy)
    $0 -stop-group legacy -stop-vms  # Stop legacy runners and shut down VMs

    # Inspect VMs on darkstar
    $0 -inspect-legacy-vms

    # List and remove
    $0 -list
    $0 -remove macOS_26
    $0 -remove-all

Environment Variables:
    GITHUB_OWNER            Set default GitHub owner (default: trodemaster)
    GITHUB_REPO             Set default repository name (default: blakeports)
    RUNNER_CONFIG           JSON configuration for runners used by -start-all
                           Format: [{"type":"lima","name":"instance_name","ssh_host":""},...]
                           Types: lima, vmware
                           ssh_host: empty for local, hostname for remote

Configuration Examples:
    # Lima runners only (current)
    export RUNNER_CONFIG='[
      {"type":"lima","name":"macos-26","ssh_host":""},
      {"type":"lima","name":"macos-26-beta","ssh_host":""},
      {"type":"lima","name":"macos-15","ssh_host":""}
    ]'

Workflow Usage:
    After creating runners, use them in your workflows:
    
    jobs:
      macos-build:
        runs-on: macos-runner
      
      linux-build:
        runs-on: ubuntu-runner
      
      windows-build:
        runs-on: windows-runner

To setup runners for a different repository:
    1. Use -owner and -repo options: $0 -tart runner-name -owner username -repo reponame
    2. Or set environment variables: GITHUB_OWNER=username GITHUB_REPO=reponame $0 -tart runner-name
    3. Or navigate to that repository directory and run without overrides

EOF
}

# Function to print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Function to check if required tools are installed
check_dependencies() {
    local missing_deps=()
    
    # Check for gh CLI
    if ! command -v gh &> /dev/null; then
        missing_deps+=("gh")
    fi
    
    # Check for lima CLI
    if [ ! -x "$LIMACTL_PATH" ]; then
        missing_deps+=("lima")
    fi
    
    # Check for vmware vmrun (for Intel macOS runners only)
    local arch
    arch=$(uname -m)
    if [ "$arch" = "x86_64" ]; then
        if [ ! -x "$VMWARE_VMRUN_PATH" ]; then
            missing_deps+=("vmware")
        fi
    fi
    
    if [ ${#missing_deps[@]} -ne 0 ]; then
        print_error "Missing required dependencies: ${missing_deps[*]}"
        print_info "Please install missing dependencies:"
        for dep in "${missing_deps[@]}"; do
            case $dep in
                "gh")
                    echo "  - GitHub CLI: https://cli.github.com/"
                    ;;
                "lima")
                    echo "  - Lima: https://lima-vm.io/"
                    echo "    Expected path: $LIMACTL_PATH"
                    ;;
                "vmware")
                    echo "  - VMware Fusion: https://www.vmware.com/products/fusion.html"
                    echo "    Expected path: $VMWARE_VMRUN_PATH"
                    ;;
            esac
        done
        exit 1
    fi
}

# Function to generate GitHub runner token
generate_runner_token() {
    print_info "Generating GitHub runner token..."
    
    if [ -n "$SSH_HOST" ]; then
        print_info "Generating token on remote host: $SSH_HOST"
        # TODO: Implement remote token generation
        print_warning "Remote token generation not yet implemented"
    else
        # Generate token using gh CLI
        if ! gh auth status &> /dev/null; then
            print_error "GitHub CLI not authenticated. Please run 'gh auth login' first."
            exit 1
        fi
        
        print_info "Using repository: $GITHUB_OWNER/$GITHUB_REPO"
        token=$(gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners/registration-token --method POST --jq '.token' 2>/dev/null)
        if [ $? -ne 0 ] || [ -z "$token" ]; then
            print_error "Failed to generate runner registration token for $GITHUB_OWNER/$GITHUB_REPO. Check your permissions."
            print_info "Make sure you have admin access to the repository or 'Manage runners' permission."
            exit 1
        fi
        # Store token for use in runner setup
        RUNNER_TOKEN="$token"
        print_success "Generated runner registration token for $GITHUB_OWNER/$GITHUB_REPO"
    fi
}

# Function to generate runner labels based on type and architecture
generate_runner_labels() {
    local runner_type=$1
    local os_type=$2
    local arch=$3
    
    local labels="self-hosted"
    
    # Add OS-specific labels
    case "$os_type" in
        "Darwin")
            labels="$labels,macOS"
            ;;
        "Linux")
            labels="$labels,Linux"
            ;;
        *)
            labels="$labels,unknown-os"
            ;;
    esac
    
    # Add runner type label
    labels="$labels,$runner_type"
    
    # Add architecture label
    case "$arch" in
        "x86_64")
            labels="$labels,x64"
            ;;
        "arm64")
            labels="$labels,ARM64"
            ;;
        "aarch64")
            labels="$labels,ARM64"
            ;;
        *)
            labels="$labels,$arch"
            ;;
    esac
    
    echo "$labels"
}

# Function to parse and validate runner configuration
parse_runner_config() {
    local config="$1"
    
    # Validate JSON format
    if ! echo "$config" | jq empty 2>/dev/null; then
        print_error "Invalid JSON format in runner configuration"
        return 1
    fi
    
    # Check if it's an array
    if ! echo "$config" | jq -e 'type == "array"' >/dev/null 2>&1; then
        print_error "Runner configuration must be a JSON array"
        return 1
    fi
    
    # Validate each runner configuration
    local runner_count
    runner_count=$(echo "$config" | jq length)
    
    if [ "$runner_count" -eq 0 ]; then
        print_warning "No runners configured"
        return 0
    fi
    
    for ((i=0; i<runner_count; i++)); do
        local runner_type name ssh_host
        runner_type=$(echo "$config" | jq -r ".[$i].type // empty")
        name=$(echo "$config" | jq -r ".[$i].name // empty")
        ssh_host=$(echo "$config" | jq -r ".[$i].ssh_host // empty")
        
        if [ -z "$runner_type" ] || [ -z "$name" ]; then
            print_error "Runner configuration at index $i missing required fields (type, name)"
            return 1
        fi
        
        # Validate runner type
        case "$runner_type" in
            "lima"|"vmware")
                ;;
            *)
                print_error "Invalid runner type '$runner_type' at index $i. Must be: lima or vmware"
                return 1
                ;;
        esac
    done
    
    return 0
}

# Function to get runner configuration count
get_runner_config_count() {
    local config="$1"
    echo "$config" | jq length 2>/dev/null || echo "0"
}

# Function to get runner configuration at specific index
get_runner_config_at_index() {
    local config="$1"
    local index="$2"
    
    local runner_type name ssh_host labels description
    runner_type=$(echo "$config" | jq -r ".[$index].type // empty")
    name=$(echo "$config" | jq -r ".[$index].name // empty")
    ssh_host=$(echo "$config" | jq -r ".[$index].ssh_host // empty")
    labels=$(echo "$config" | jq -r ".[$index].labels // empty")
    description=$(echo "$config" | jq -r ".[$index].description // empty")
    
    # Return as delimited string for easy parsing
    echo "$runner_type:$name:$ssh_host:$labels:$description"
}

# Function to debug basic connectivity to VM
debug_vm_connectivity() {
    local vm_ip=$1
    
    print_info "=== VM Connectivity Debug ==="
    print_info "VM IP: $vm_ip"
    
    # Test basic ping
    print_info "Testing ping to $vm_ip..."
    if ping -c 3 -W 3000 "$vm_ip" &>/dev/null; then
        print_success "Ping successful"
    else
        print_error "Ping failed - VM may not be reachable"
        return 1
    fi
    
    # Test if SSH port is open
    print_info "Testing SSH port (22) connectivity..."
    if nc -z -w 5 "$vm_ip" 22 2>/dev/null; then
        print_success "SSH port 22 is open"
    else
        print_error "SSH port 22 is not accessible"
        return 1
    fi
    
    # Test SSH with verbose output (first attempt only)
    print_info "Testing SSH with verbose output (first attempt)..."
    local ssh_verbose_output
    ssh_verbose_output=$(ssh -v "${SSH_OPTS[@]}" -o ConnectTimeout=10 admin@"$vm_ip" "echo 'SSH test'" 2>&1)
    local ssh_verbose_exit_code=$?
    
    if [ $ssh_verbose_exit_code -eq 0 ]; then
        print_success "SSH verbose test successful"
    else
        print_error "SSH verbose test failed (exit code: $ssh_verbose_exit_code)"
        print_error "SSH verbose output:"
        echo "$ssh_verbose_output" | head -20 | while IFS= read -r line; do
            print_error "  $line"
        done
    fi
    
    print_info "=== End VM Connectivity Debug ==="
    return 0
}

# Function to test SSH connection with retries
test_ssh_connection_with_retries() {
    local vm_ip=$1
    local use_legacy_ssh=${2:-false}  # Optional parameter for legacy SSH
    local max_attempts=24  # 24 attempts * 5 seconds = 2 minutes
    local attempt=0

    # Determine which SSH command and options to use
    local ssh_cmd="ssh"
    local ssh_user="admin"
    local ssh_opts_array=("${SSH_OPTS[@]}")

    if [ "$use_legacy_ssh" = "true" ]; then
        ssh_cmd="$LEGACY_SSH_CMD"
        ssh_user="$VMWARE_VM_USER"
        ssh_opts_array=("${LEGACY_SSH_OPTS[@]}")
    fi

    print_info "Testing SSH connection to $ssh_user@$vm_ip (will retry for up to 2 minutes)..."
    print_info "Using SSH command: $ssh_cmd"

    # Run connectivity debug first if debug mode is enabled
    if [ "$DEBUG_MODE" = "true" ]; then
        debug_vm_connectivity "$vm_ip"
    fi

    while [ $attempt -lt $max_attempts ]; do
        attempt=$((attempt + 1))

        # Try SSH connection and capture both stdout and stderr for debugging
        local ssh_output
        local ssh_exit_code

        print_info "SSH attempt $attempt/$max_attempts"

        # Capture SSH output for debugging
        ssh_output=$($ssh_cmd "${ssh_opts_array[@]}" -o ConnectTimeout=5 $ssh_user@"$vm_ip" "echo 'SSH connection successful'" 2>&1)
        ssh_exit_code=$?

        if [ $ssh_exit_code -eq 0 ]; then
            print_success "SSH connection established (attempt $attempt/$max_attempts)"
            return 0
        else
            print_warning "SSH attempt $attempt failed (exit code: $ssh_exit_code)"
            if [ -n "$ssh_output" ]; then
                print_error "SSH error details:"
                echo "$ssh_output" | while IFS= read -r line; do
                    print_error "  $line"
                done
            else
                print_error "No SSH error output captured"
            fi
        fi

        if [ $attempt -lt $max_attempts ]; then
            print_info "SSH connection attempt $attempt/$max_attempts failed, retrying in 5 seconds..."
            sleep 5
        fi
    done

    print_error "SSH connection failed after $max_attempts attempts (2 minutes)"
    print_error "Troubleshooting steps:"
    print_error "  1. Verify VM is fully booted"
    print_error "  2. Check if SSH service is running on the VM"
    print_error "  3. Verify the $ssh_user user exists and has SSH access"
    print_error "  4. Try connecting manually: $ssh_cmd $ssh_user@$vm_ip"
    print_error "  5. Check if the VM IP is correct: $vm_ip"
    print_error "  6. Verify SSH key authentication is working"
    return 1
}

# Function to detect primary network interface for bridged networking
detect_primary_network_interface() {
    # Try to get the primary network interface
    # On macOS, this is usually en0 (Ethernet) or en1 (Wi-Fi)
    local primary_iface
    
    # Check for active Ethernet interface first
    primary_iface=$(route get default 2>/dev/null | grep interface | awk '{print $2}')
    
    if [ -z "$primary_iface" ]; then
        # Fallback: try to find first active non-loopback interface
        primary_iface=$(ifconfig | grep -E "^[a-z]" | grep -v lo0 | head -1 | cut -d: -f1)
    fi
    
    if [ -z "$primary_iface" ]; then
        # Last resort: use en0 as default
        primary_iface="en0"
        print_warning "Could not detect primary network interface, using default: $primary_iface"
    else
        print_info "Detected primary network interface: $primary_iface"
    fi
    
    echo "$primary_iface"
}

# Function to detect VM architecture and get appropriate runner package
detect_vm_architecture() {
    local vm_ip=$1
    local runner_version=$2
    local use_legacy_ssh=${3:-false}  # Optional parameter for legacy SSH

    # Determine which SSH command and options to use
    local ssh_cmd="ssh"
    local ssh_user="admin"
    local ssh_opts_array=("${SSH_OPTS[@]}")

    if [ "$use_legacy_ssh" = "true" ]; then
        ssh_cmd="$LEGACY_SSH_CMD"
        ssh_user="$VMWARE_VM_USER"
        ssh_opts_array=("${LEGACY_SSH_OPTS[@]}")
    fi

    print_info "Detecting VM architecture..." >&2

    # Get system architecture
    local arch
    arch=$($ssh_cmd "${ssh_opts_array[@]}" $ssh_user@"$vm_ip" "uname -m" 2>/dev/null)
    if [ $? -ne 0 ]; then
        print_error "Failed to detect VM architecture" >&2
        return 1
    fi

    # Get OS type
    local os_type
    os_type=$($ssh_cmd "${ssh_opts_array[@]}" $ssh_user@"$vm_ip" "uname -s" 2>/dev/null)
    if [ $? -ne 0 ]; then
        print_error "Failed to detect VM OS type" >&2
        return 1
    fi

    print_info "Detected OS: $os_type, Architecture: $arch" >&2
    
    # Determine runner package based on OS and architecture
    local runner_package=""
    case "$os_type" in
        "Darwin")
            case "$arch" in
                "x86_64")
                    runner_package="actions-runner-osx-x64-${runner_version}.tar.gz"
                    ;;
                "arm64")
                    runner_package="actions-runner-osx-arm64-${runner_version}.tar.gz"
                    ;;
                *)
                    print_error "Unsupported macOS architecture: $arch" >&2
                    return 1
                    ;;
            esac
            ;;
        "Linux")
            case "$arch" in
                "x86_64")
                    runner_package="actions-runner-linux-x64-${runner_version}.tar.gz"
                    ;;
                "aarch64"|"arm64")
                    runner_package="actions-runner-linux-arm64-${runner_version}.tar.gz"
                    ;;
                *)
                    print_error "Unsupported Linux architecture: $arch" >&2
                    return 1
                    ;;
            esac
            ;;
        *)
            print_error "Unsupported OS type: $os_type" >&2
            return 1
            ;;
    esac
    
    echo "$runner_package"
    return 0
}

# Map Lima instance name to GitHub Actions runner label
# Lima instance names use lowercase-hyphen; runner labels use camelCase_underscore
get_runner_label_for_instance() {
    local instance_name=$1
    case "$instance_name" in
        "macos-26")       echo "macOS_26" ;;
        "macos-26-beta")  echo "macOS_26_beta" ;;
        "macos-15")       echo "macOS_15" ;;
        *)                echo "$instance_name" ;;
    esac
}

# Map GitHub Actions runner label back to Lima instance name
get_lima_instance_for_label() {
    local runner_label=$1
    case "$runner_label" in
        "macOS_26")      echo "macos-26" ;;
        "macOS_26_beta") echo "macos-26-beta" ;;
        "macOS_15")      echo "macos-15" ;;
        *)               echo "" ;;
    esac
}

# Function to start a Lima macOS runner
start_lima_runner() {
    local instance_name=$1
    local runner_label
    runner_label=$(get_runner_label_for_instance "$instance_name")

    print_info "Starting lima runner: $instance_name (label: $runner_label)"

    if [ ! -x "$LIMACTL_PATH" ]; then
        print_error "Lima CLI not found at: $LIMACTL_PATH"
        exit 1
    fi

    # Verify the instance is running
    local instance_status
    instance_status=$("$LIMACTL_PATH" list 2>/dev/null | awk -v name="$instance_name" '$1 == name {print $2}')
    if [ "$instance_status" != "Running" ]; then
        print_error "Lima instance '$instance_name' is not running (status: ${instance_status:-not found})"
        print_info "Start it first: limactl start $instance_name"
        exit 1
    fi
    print_success "Lima instance '$instance_name' is running"

    local ssh_config="$HOME/.lima/$instance_name/ssh.config"
    local ssh_target="lima-$instance_name"

    if [ ! -f "$ssh_config" ]; then
        print_error "Lima SSH config not found: $ssh_config"
        exit 1
    fi

    # Wait for SSH to be available
    print_info "Waiting for SSH on $ssh_target..."
    local attempt=0
    local max_attempts=12
    local ssh_ok=false
    while [ $attempt -lt $max_attempts ]; do
        attempt=$((attempt + 1))
        if ssh -F "$ssh_config" -o ConnectTimeout=5 -o StrictHostKeyChecking=no "$ssh_target" "echo ok" &>/dev/null; then
            ssh_ok=true
            break
        fi
        print_info "SSH attempt $attempt/$max_attempts, retrying in 5s..."
        sleep 5
    done
    if [ "$ssh_ok" = false ]; then
        print_error "Failed to establish SSH connection to $ssh_target after $max_attempts attempts"
        exit 1
    fi
    print_success "SSH connection established to $ssh_target"

    # Detect OS and architecture
    local vm_os vm_arch
    vm_os=$(ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" "uname -s" 2>/dev/null)
    vm_arch=$(ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" "uname -m" 2>/dev/null)
    print_info "VM OS: $vm_os, Arch: $vm_arch"

    # Get latest stable runner version
    local runner_version
    runner_version=$(curl -fsSL https://api.github.com/repos/actions/runner/releases/latest | jq -r '.tag_name' | sed 's/v//')
    print_info "Runner version: $runner_version"

    # Determine runner package
    local runner_package
    case "$vm_os" in
        "Darwin")
            case "$vm_arch" in
                "arm64")  runner_package="actions-runner-osx-arm64-${runner_version}.tar.gz" ;;
                "x86_64") runner_package="actions-runner-osx-x64-${runner_version}.tar.gz" ;;
                *) print_error "Unsupported macOS arch: $vm_arch"; exit 1 ;;
            esac ;;
        "Linux")
            case "$vm_arch" in
                "aarch64"|"arm64") runner_package="actions-runner-linux-arm64-${runner_version}.tar.gz" ;;
                "x86_64")          runner_package="actions-runner-linux-x64-${runner_version}.tar.gz" ;;
                *) print_error "Unsupported Linux arch: $vm_arch"; exit 1 ;;
            esac ;;
        *) print_error "Unsupported OS: $vm_os"; exit 1 ;;
    esac

    local runner_url="https://github.com/actions/runner/releases/download/v${runner_version}/${runner_package}"
    local runner_labels="self-hosted,macOS,ARM64,$runner_label"
    print_info "Package: $runner_package"
    print_info "Labels:  $runner_labels"

    # Check if runner is already configured on disk
    local already_configured
    already_configured=$(ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
        '[ -f /opt/actions-runner/.runner ] && echo yes || echo no' 2>/dev/null)

    if [ "$already_configured" = "yes" ]; then
        print_info "Runner already configured on disk — skipping download/configure"
    else
        # Download runner into VM
        print_info "Downloading GitHub runner..."
        ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
            "curl -fsSL -o /tmp/actions-runner.tar.gz '$runner_url'"
        if [ $? -ne 0 ]; then
            print_error "Failed to download GitHub runner"
            exit 1
        fi

        # Extract runner
        print_info "Extracting runner..."
        ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
            "sudo mkdir -p /opt/actions-runner && \
             sudo tar -xzf /tmp/actions-runner.tar.gz -C /opt/actions-runner && \
             sudo chown -R \$(whoami):\$(id -gn) /opt/actions-runner && \
             rm /tmp/actions-runner.tar.gz"

        # Configure runner
        print_info "Configuring runner..."
        ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
            "cd /opt/actions-runner && \
             ./config.sh \
               --url 'https://github.com/$GITHUB_OWNER/$GITHUB_REPO' \
               --token '$RUNNER_TOKEN' \
               --name '$runner_label' \
               --labels '$runner_labels' \
               --unattended --replace"
        if [ $? -ne 0 ]; then
            print_error "Failed to configure GitHub runner"
            exit 1
        fi
    fi

    # Install and start service
    print_info "Installing runner service (if not already installed)..."
    ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
        'cd /opt/actions-runner && ([ -f .service ] && echo "Service already installed" || ./svc.sh install)'
    if [ $? -ne 0 ]; then print_error "Failed to install runner service"; exit 1; fi

    # Start the service. On macOS, LaunchAgents require an active GUI session
    # (gui/<uid> launchd domain). If the user has not yet logged in via the
    # macOS desktop, bootstrap will fail here. The service IS installed and will
    # start automatically on the next GUI login or VM reboot (if auto-login is
    # enabled in configure.sh).
    print_info "Starting runner service..."
    local start_ok=false
    local plist_path
    plist_path=$(ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
        "ls \$HOME/Library/LaunchAgents/actions.runner.*.plist 2>/dev/null | head -1")

    if [ -n "$plist_path" ]; then
        # Try launchctl bootstrap (macOS 10.15+)
        if ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
            "uid=\$(id -u); launchctl bootstrap gui/\$uid '$plist_path'" 2>/dev/null; then
            start_ok=true
        # Fall back to legacy launchctl load
        elif ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
            "launchctl load -w '$plist_path'" 2>/dev/null; then
            start_ok=true
        fi
    fi

    if [ "$start_ok" = true ]; then
        print_success "Runner '$runner_label' is now running on Lima instance '$instance_name'"
        print_info "Runner service status:"
        ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
            "cd /opt/actions-runner && ./svc.sh status"
    else
        print_warning "════════════════════════════════════════════════════════════════"
        print_warning "  RUNNER INSTALLED — WAITING FOR GUI SESSION"
        print_warning "════════════════════════════════════════════════════════════════"
        print_warning ""
        print_warning "  Runner '$runner_label' is registered with GitHub and the"
        print_warning "  LaunchAgent service is installed, but could not be started"
        print_warning "  because no GUI session exists yet (gui/$uid launchd domain"
        print_warning "  only appears after the user logs into the macOS desktop)."
        print_warning ""
        print_warning "  To start the runner now:"
        print_warning "    1. Log into the VM window (macOS login screen → desktop)"
        print_warning "    2. The LaunchAgent will start automatically on login"
        print_warning ""
        print_warning "  For fully automated startup, enable auto-login in the VM:"
        print_warning "    System Settings → Users & Groups → Automatic login"
        print_warning "    OR: run configure.sh with AUTO_LOGIN=1"
        print_warning ""
        print_warning "════════════════════════════════════════════════════════════════"
        print_success "Runner '$runner_label' registered and service installed (start pending GUI login)"
    fi
}

# Function to call VMware Fusion REST API

# Function to inspect legacy runner VMs on darkstar
inspect_legacy_vms() {
    print_info "════════════════════════════════════════════════════════════════════"
    print_info "  VMware Fusion Legacy VM Inspection (darkstar)"
    print_info "════════════════════════════════════════════════════════════════════"
    echo
    
    print_info "Querying VMs via SSH to darkstar..."
    
    # Get list of running VMs
    # Use simple SSH - user's SSH config is properly configured
    local vm_list
    vm_list=$(ssh darkstar "\"$VMWARE_VMRUN_PATH\" list" 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        print_error "Failed to connect to darkstar via SSH or vmrun not available"
        print_error "Please ensure:"
        print_error "  1. SSH access to darkstar is configured"
        print_error "  2. vmrun is available on darkstar"
        return 1
    fi
    
    echo "$vm_list" | grep -v "^Total" | head -1
    local running_count=$(echo "$vm_list" | grep "^Total" | awk '{print $4}')
    echo
    
    # Section 1: Base Images
    print_info "──────────────────────────────────────────────────────────────────"
    print_info "BASE IMAGES (Templates)"
    print_info "──────────────────────────────────────────────────────────────────"
    echo
    
    local base_vms
    base_vms=$(ssh darkstar "ls -1 '$VMWARE_BASE_DIR' | grep -E '.*-base\.vmwarevm$'" 2>/dev/null)
    
    if [ -z "$base_vms" ]; then
        print_warning "  No base images found"
    else
        while IFS= read -r vm; do
            local vm_name=$(echo "$vm" | sed 's/\.vmwarevm$//')
            printf "  ✓ %s\n" "$vm_name"
        done <<< "$base_vms"
    fi
    echo
    
    # Section 2: Runner VMs
    print_info "──────────────────────────────────────────────────────────────────"
    print_info "RUNNER VMs (Active Instances)"
    print_info "──────────────────────────────────────────────────────────────────"
    echo
    
    printf "%-30s %-12s\n" "RUNNER NAME" "POWER STATE"
    echo "────────────────────────────────────────────────────────────────────"
    
    local runner_vms
    runner_vms=$(ssh darkstar "ls -1 '$VMWARE_BASE_DIR' | grep -E '^runner-.*\.vmwarevm$' | grep -v -- '-base\.vmwarevm$'" 2>/dev/null)
    
    if [ -z "$runner_vms" ]; then
        print_warning "  No runner VMs found"
    else
        while IFS= read -r vm; do
            local vm_name=$(echo "$vm" | sed 's/\.vmwarevm$//')
            local vm_path="$VMWARE_BASE_DIR/$vm/${vm_name}.vmx"
            
            # Check if VM is running by looking in the running list
            if echo "$vm_list" | grep -q "$vm_path"; then
                printf "%-30s ${GREEN}%-12s${NC}\n" "$vm_name" "running"
            else
                printf "%-30s ${YELLOW}%-12s${NC}\n" "$vm_name" "stopped"
            fi
        done <<< "$runner_vms"
    fi
    echo
    
    # Section 3: Docker Containers
    print_info "──────────────────────────────────────────────────────────────────"
    print_info "DOCKER CONTAINERS (Connected to Runners)"
    print_info "──────────────────────────────────────────────────────────────────"
    echo
    
    # Check if docker is available
    if ! command -v docker &> /dev/null; then
        print_warning "Docker not available for container inspection"
        echo
    else
        printf "%-30s %-12s %s\n" "CONTAINER NAME" "STATUS" "IMAGE"
        echo "────────────────────────────────────────────────────────────────────"
        
        local container_count=0
        for runner in "${LEGACY_RUNNERS[@]}"; do
            local container_name="${runner}-runner"
            
            # Check if container exists
            local container_info
            container_info=$(docker ps -a --filter "name=^${container_name}$" --format "{{.Names}}|{{.State}}|{{.Image}}" 2>/dev/null)
            
            if [ -n "$container_info" ]; then
                container_count=$((container_count + 1))
                local container_status=$(echo "$container_info" | cut -d'|' -f2)
                local container_image=$(echo "$container_info" | cut -d'|' -f3)
                
                # Color code container status
                local status_display
                case "$container_status" in
                    "running")
                        status_display="${GREEN}running${NC}"
                        ;;
                    "exited")
                        status_display="${YELLOW}stopped${NC}"
                        ;;
                    "paused")
                        status_display="${YELLOW}paused${NC}"
                        ;;
                    *)
                        status_display="${RED}${container_status}${NC}"
                        ;;
                esac
                
                printf "%-30s %-12b %s\n" "$container_name" "$status_display" "$container_image"
            fi
        done
        
        if [ "$container_count" = "0" ]; then
            print_warning "  No legacy runner containers found"
        fi
        echo
    fi
    
    # Summary
    print_info "════════════════════════════════════════════════════════════════════"
    print_info "SUMMARY"
    print_info "════════════════════════════════════════════════════════════════════"
    echo
    print_info "Configured legacy runners in ghrunner:"
    for runner in "${LEGACY_RUNNERS[@]}"; do
        print_info "  • runner-$runner"
    done
    echo
    print_success "Inspection complete. Running VMs: $running_count"
}

# Function to start legacy docker runner
start_legacy_docker_runner() {
    local runner_name=$1
    print_info "Starting legacy docker runner: $runner_name"
    
    # Check if docker is available
    if ! command -v docker &> /dev/null; then
        print_error "Docker not found"
        exit 1
    fi
    
    # Check if jq is available
    if ! command -v jq &> /dev/null; then
        print_error "jq not found - required for JSON config management"
        exit 1
    fi
    
    # Get VM info for this runner
    local vm_name="${runner_name}"
    local vm_hostname="${runner_name}-runner.local"
    
    # Start the VMware VM on darkstar if needed
    if ! start_vmware_vm_if_needed "$vm_name"; then
        print_error "Failed to start VMware VM for $runner_name"
        exit 1
    fi
    
    # Verify VM is accessible
    if ! test_ssh_connection_with_retries "$vm_hostname" true; then
        print_error "Cannot reach VM at $vm_hostname"
        exit 1
    fi
    
    # Resolve Bonjour hostname to IP address for Docker container
    print_info "Resolving Bonjour hostname to IP address..."
    local vm_ip
    vm_ip=$(ping -c 1 "$vm_hostname" 2>/dev/null | grep -oE '\([0-9.]+\)' | head -1 | tr -d '()')
    
    if [ -z "$vm_ip" ]; then
        print_warning "Could not resolve $vm_hostname to IP, trying alternative method..."
        # Try using dig if ping doesn't work
        vm_ip=$(dig +short "$vm_hostname" @224.0.0.251 2>/dev/null | head -1)
    fi
    
    if [ -z "$vm_ip" ]; then
        print_error "Failed to resolve $vm_hostname to IP address"
        exit 1
    fi
    
    print_success "Resolved $vm_hostname to IP: $vm_ip"
    
    # Generate runner token
    print_info "Generating runner token..."
    local token
    token=$(gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners/registration-token --method POST --jq '.token')
    
    if [ -z "$token" ]; then
        print_error "Failed to generate runner token"
        exit 1
    fi
    
    # Update JSON config file
    local docker_dir="/Users/blake/Developer/blakeports/docker"
    local config_dir="$docker_dir/config"
    local config_file="$config_dir/runners.json"
    
    # Ensure config directory exists
    mkdir -p "$config_dir"
    
    # Copy SSH keys to config directory (if they exist in blakeports)
    local ssh_key_src="/Users/blake/Developer/blakeports/docker/ssh_keys/oldmac"
    if [ -f "$ssh_key_src" ]; then
        mkdir -p "$config_dir/ssh_keys"
        cp "$ssh_key_src" "$config_dir/ssh_keys/oldmac"
        chmod 600 "$config_dir/ssh_keys/oldmac"
        print_info "SSH key copied to config/ssh_keys/"
    fi
    
    # Initialize config file from example if it doesn't exist
    if [ ! -f "$config_file" ]; then
        print_info "Creating config from example..."
        cp "$docker_dir/config.example.json" "$config_file"
    fi
    
    # Update runner config using jq
    print_info "Updating runner config: $runner_name"
    local tmp_file=$(mktemp)
    jq --arg name "$runner_name" \
       --arg token "$token" \
       --arg vm_ip "$vm_ip" \
       --arg owner "$GITHUB_OWNER" \
       --arg repo "$GITHUB_REPO" \
       '.runners[$name].token = $token | 
        .runners[$name].vm_ip = $vm_ip |
        .github.owner = $owner |
        .github.repo = $repo' \
       "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
    
    print_success "Config updated: token and IP for $runner_name"
    
    # Restart the container to pick up new config
    cd "$docker_dir"
    print_info "Restarting ${runner_name}-runner container..."
    docker compose up -d --force-recreate "${runner_name}-runner"
    
    # Wait a moment for container to start
    sleep 2
    
    # Verify config is accessible in the container
    print_info "Verifying config is accessible in container..."
    if docker compose exec "${runner_name}-runner" test -f /config/runners.json; then
        print_success "✅ Config file is accessible in container"
    else
        print_error "❌ Config file NOT accessible in container - mount may have failed"
        return 1
    fi
    
    print_success "Docker runner $runner_name started with IP: $vm_ip"
}

# Function to stop legacy docker runner
stop_legacy_docker_runner() {
    local runner_name=$1
    print_info "Stopping legacy docker runner: $runner_name"
    
    local docker_dir="/Users/blake/Developer/blakeports/docker"
    cd "$docker_dir"
    docker compose stop "${runner_name}-runner" 2>/dev/null || print_warning "Container may not be running"
    
    print_success "Docker runner $runner_name stopped"
}

# Function to start VMware VM on darkstar if not running
# Note: Linked clone VMs must be pre-created manually on darkstar
start_vmware_vm_if_needed() {
    local vm_name=$1
    local instance_vm_name="runner-${vm_name}"
    local vm_path="$VMWARE_BASE_DIR/${instance_vm_name}.vmwarevm/${instance_vm_name}.vmx"
    
    print_info "Checking if VM $instance_vm_name is running on darkstar..."
    
    # Check if VM is already running
    # Use simple SSH - user's SSH config is properly configured
    local vm_list
    vm_list=$(ssh darkstar "\"$VMWARE_VMRUN_PATH\" list" 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        print_error "Failed to connect to darkstar via SSH or vmrun not available"
        print_error "Please ensure SSH access to darkstar is configured"
        return 1
    fi
    
    if echo "$vm_list" | grep -q "$vm_path"; then
        print_success "VM $instance_vm_name is already running"
        return 0
    fi
    
    # VM is not running - prompt for manual start and poll
    print_warning "════════════════════════════════════════════════════════════════"
    print_warning "  MANUAL VM STARTUP REQUIRED"
    print_warning "════════════════════════════════════════════════════════════════"
    print_warning ""
    print_warning "  VM not running: $instance_vm_name"
    print_warning ""
    print_warning "  On darkstar, start it via:"
    print_warning "    1. VMware Fusion GUI"
    print_warning "    2. vmrun command:"
    print_warning "       vmrun start \"$vm_path\""
    print_warning ""
    print_warning "  Polling every 5 seconds for 3 minutes..."
    print_warning "  Press Ctrl+C to cancel"
    print_warning ""
    print_warning "════════════════════════════════════════════════════════════════"
    echo
    
    # Poll for VM to appear in running list
    local max_attempts=36  # 36 * 5 seconds = 3 minutes
    local attempt=0
    
    while [ $attempt -lt $max_attempts ]; do
        attempt=$((attempt + 1))
        
        printf "[%2d/%2d] Checking if VM is running..." $attempt $max_attempts
        
        vm_list=$(ssh darkstar "\"$VMWARE_VMRUN_PATH\" list" 2>/dev/null)
        
        if echo "$vm_list" | grep -q "$vm_path"; then
            echo ""
            print_success "VM $instance_vm_name detected as running!"
            
            # Give it a few more seconds to fully boot
            print_info "Waiting 10 seconds for VM to fully boot..."
            sleep 10
            
            return 0
        fi
        
        echo " not yet"
        
        if [ $attempt -lt $max_attempts ]; then
            sleep 5
        fi
    done
    
    echo ""
    print_error "Timeout: VM did not start within 3 minutes"
    print_error "Please check darkstar and ensure VM started successfully"
    return 1
}

# Function to stop VMware VM on darkstar (manual)
stop_vmware_vm() {
    local vm_name=$1
    local instance_vm_name="runner-${vm_name}"
    
    print_warning "════════════════════════════════════════════════════════════════"
    print_warning "  MANUAL VM SHUTDOWN REQUIRED"
    print_warning "════════════════════════════════════════════════════════════════"
    print_warning ""
    print_warning "  Please manually stop the VM: $instance_vm_name"
    print_warning ""
    print_warning "  On darkstar, you can stop it via:"
    print_warning "    1. VMware Fusion GUI"
    print_warning "    2. vmrun command:"
    print_warning "       vmrun stop \"$VMWARE_BASE_DIR/${instance_vm_name}.vmwarevm/${instance_vm_name}.vmx\""
    print_warning ""
    print_warning "════════════════════════════════════════════════════════════════"
    
    return 0
}

# Function to get VMware VM path on remote host
get_vmware_vm_path() {
    local vm_name=$1
    echo "$VMWARE_BASE_DIR/${vm_name}.vmwarevm/${vm_name}.vmx"
}

# Function to get VMware base VM path
get_vmware_base_vm_path() {
    local base_name=$1
    echo "$VMWARE_BASE_DIR/runner-${base_name}-base.vmwarevm/runner-${base_name}-base.vmx"
}

# Function to check if VMware VM exists on remote host
vmware_vm_exists() {
    local vm_name=$1
    local vm_path=$(get_vmware_vm_path "$vm_name")

    if ssh "$VMWARE_SSH_HOST" "test -f '$vm_path'"; then
        return 0
    else
        return 1
    fi
}

# Function to get VMware VM hostname
get_vmware_vm_hostname() {
    local base_vm_name=$1
    # Legacy VMs use predictable hostnames: {version}-runner.local
    echo "${base_vm_name}-runner.local"
}

# Function to start runner group
start_runner_group() {
    local group=$1
    
    case $group in
        "current")
            print_info "Starting current group (lima runners)"
            for runner in "${CURRENT_RUNNERS[@]}"; do
                print_info "Starting lima runner: $runner"
                generate_runner_token
                start_lima_runner "$runner"
            done
            ;;
        "legacy")
            print_info "Starting legacy group (docker+VMware runners)"
            for runner in "${LEGACY_RUNNERS[@]}"; do
                print_info "Starting legacy docker runner: $runner"
                generate_runner_token
                start_legacy_docker_runner "$runner"
            done
            ;;
        "all")
            print_info "Starting all runner groups"
            start_runner_group "current"
            start_runner_group "legacy"
            ;;
        *)
            print_error "Unknown group: $group"
            exit 1
            ;;
    esac
    
    print_success "Group '$group' started"
}

# Function to stop runner group
stop_runner_group() {
    local group=$1
    local stop_vms=${2:-false}
    
    case $group in
        "current")
            print_info "Stopping current group (lima runners)"
            for runner in "${CURRENT_RUNNERS[@]}"; do
                if "$LIMACTL_PATH" list 2>/dev/null | awk '{print $1}' | grep -q "^$runner$"; then
                    print_info "Stopping Lima instance: $runner"
                    "$LIMACTL_PATH" stop "$runner" 2>/dev/null || print_warning "Instance may already be stopped"
                else
                    print_info "Lima instance '$runner' not found, skipping"
                fi
            done
            ;;
        "legacy")
            print_info "Stopping legacy group (docker runners)"
            local docker_dir="/Users/blake/Developer/blakeports/docker"
            if [ -d "$docker_dir" ]; then
                cd "$docker_dir"
                docker compose down 2>/dev/null || print_warning "Docker compose may not be running"
            fi
            
            if [ "$stop_vms" = "true" ]; then
                print_info "Stopping VMware VMs on darkstar"
                for runner in "${LEGACY_RUNNERS[@]}"; do
                    stop_vmware_vm "$runner"
                done
            fi
            ;;
        "all")
            print_info "Stopping all runner groups"
            stop_runner_group "current"
            stop_runner_group "legacy" "$stop_vms"
            ;;
        *)
            print_error "Unknown group: $group"
            exit 1
            ;;
    esac
    
    print_success "Group '$group' stopped"
}

# Function to start vmware runner
# NOTE: This function is deprecated. Use docker-based legacy runners instead.
# Kept for reference only. Use start_legacy_docker_runner() for new deployments.
start_vmware_runner() {
    local runner_name=$1
    
    print_info "Starting legacy VMware runner: $runner_name"
    print_info "Using Docker container with REST API VM management"
    
    # Use the legacy docker approach (which now uses REST API)
    generate_runner_token
    start_legacy_docker_runner "$runner_name"
}

# Helper function to start a single runner (for parallel execution)
start_single_runner_parallel() {
    local runner_type="$1"
    local name="$2"
    local ssh_host="$3"
    local runner_token="$4"
    local index="$5"
    local temp_dir="$6"
    
    # Create result file for this runner
    local result_file="$temp_dir/runner_$index.result"
    local log_file="$temp_dir/runner_$index.log"
    
    # Set up environment for this runner
    local original_ssh_host="$SSH_HOST"
    if [ -n "$ssh_host" ]; then
        SSH_HOST="$ssh_host"
    fi
    
    # Use the shared token
    RUNNER_TOKEN="$runner_token"
    
    # Redirect output to log file and capture result
    exec > "$log_file" 2>&1
    
    print_info "Starting runner $((index+1)): $name ($runner_type)"
    if [ -n "$ssh_host" ]; then
        print_info "Using SSH host: $ssh_host"
    fi
    
    # Start the runner based on type
    case "$runner_type" in
        "lima")
            if start_lima_runner "$name"; then
                echo "SUCCESS:$name:$runner_type" > "$result_file"
                print_success "Successfully started lima runner: $name"
            else
                echo "FAILURE:$name:$runner_type" > "$result_file"
                print_error "Failed to start lima runner: $name"
            fi
            ;;
        "vmware")
            if start_vmware_runner "$name"; then
                echo "SUCCESS:$name:$runner_type" > "$result_file"
                print_success "Successfully started vmware runner: $name"
            else
                echo "FAILURE:$name:$runner_type" > "$result_file"
                print_error "Failed to start vmware runner: $name"
            fi
            ;;
        *)
            echo "FAILURE:$name:$runner_type:Unknown runner type" > "$result_file"
            print_error "Unknown runner type: $runner_type"
            ;;
    esac
    
    # Restore original SSH_HOST
    SSH_HOST="$original_ssh_host"
}

# Function to start all runners
start_all_runners() {
    print_info "Starting all configured runners..."
    
    # Parse and validate configuration
    if ! parse_runner_config "$RUNNER_CONFIG"; then
        print_error "Failed to parse runner configuration"
        exit 1
    fi
    
    local runner_count
    runner_count=$(get_runner_config_count "$RUNNER_CONFIG")
    
    if [ "$runner_count" -eq 0 ]; then
        print_warning "No runners configured to start"
        return 0
    fi
    
    print_info "Found $runner_count configured runner(s)"
    
    # Generate GitHub token once for all runners
    generate_runner_token
    
    # Create temporary directory for parallel execution results
    local temp_dir=$(mktemp -d)
    local pids=()
    
    print_info "Starting all runners in parallel..."
    
    # Start each configured runner in parallel
    for ((i=0; i<runner_count; i++)); do
        local runner_config runner_type name ssh_host labels description
        runner_config=$(get_runner_config_at_index "$RUNNER_CONFIG" "$i")
        
        # Parse the configuration
        IFS=':' read -r runner_type name ssh_host labels description <<< "$runner_config"
        
        print_info "Initiating parallel start for runner $((i+1))/$runner_count: $name ($runner_type)"
        
        # Start runner in background
        start_single_runner_parallel "$runner_type" "$name" "$ssh_host" "$RUNNER_TOKEN" "$i" "$temp_dir" &
        pids+=($!)
    done
    
    print_info "All runners initiated. Waiting for completion..."
    
    # Wait for all background processes to complete
    local completed=0
    local total=${#pids[@]}
    
    for pid in "${pids[@]}"; do
        if wait "$pid"; then
            completed=$((completed + 1))
            print_info "Runner process completed ($completed/$total)"
        else
            print_warning "Runner process failed ($completed/$total)"
        fi
    done
    
    # Collect and display results
    local success_count=0
    local failure_count=0
    
    echo
    print_info "Parallel execution completed. Processing results..."
    echo
    
    # Display logs in order and count results
    for ((i=0; i<runner_count; i++)); do
        local result_file="$temp_dir/runner_$i.result"
        local log_file="$temp_dir/runner_$i.log"
        
        # Display the log output
        if [ -f "$log_file" ]; then
            cat "$log_file"
        fi
        
        # Process the result
        if [ -f "$result_file" ]; then
            local result=$(cat "$result_file")
            if [[ "$result" == SUCCESS:* ]]; then
                success_count=$((success_count + 1))
            else
                failure_count=$((failure_count + 1))
            fi
        else
            failure_count=$((failure_count + 1))
            print_error "No result file found for runner $((i+1))"
        fi
        
        # Add separator between runners (except for the last one)
        if [ $((i + 1)) -lt "$runner_count" ]; then
            echo
        fi
    done
    
    # Clean up temporary directory
    rm -rf "$temp_dir"
    
    # Print summary
    echo
    print_info "Runner startup summary:"
    print_success "Successfully started: $success_count"
    if [ "$failure_count" -gt 0 ]; then
        print_error "Failed to start: $failure_count"
    fi
    
    if [ "$success_count" -eq "$runner_count" ]; then
        print_success "All configured runners started successfully!"
    elif [ "$success_count" -eq 0 ]; then
        print_error "No runners were started successfully"
        return 1
    else
        print_warning "Some runners failed to start"
        return 1
    fi
}

# Function to stop all running workflows
stop_all_workflows() {
    print_info "Stopping all running workflows..."
    
    # Generate GitHub token to ensure we have auth and repo context
    generate_runner_token
    
    # Get list of in-progress workflow runs (try multiple statuses)
    local running_runs
    running_runs=$(gh run list --status in_progress,queued,waiting --json databaseId,id,workflowName,status --limit 100 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch running workflows for $GITHUB_OWNER/$GITHUB_REPO"
        return 1
    fi
    
    local run_count
    run_count=$(echo "$running_runs" | jq 'length' 2>/dev/null)
    
    if [ "$run_count" = "0" ] || [ -z "$run_count" ]; then
        print_info "No running workflows found"
        return 0
    fi
    
    print_info "Found $run_count workflow(s) to stop (in_progress, queued, waiting)"
    
    # Stop each running workflow
    local stopped_count=0
    while IFS='|' read -r run_id workflow_id workflow_name; do
        if [ -n "$run_id" ] && [ -n "$workflow_id" ]; then
            print_info "Stopping workflow '$workflow_name' (ID: $workflow_id)..."
            
            # Cancel the workflow run
            if gh run cancel "$workflow_id" 2>/dev/null; then
                print_success "Successfully stopped workflow '$workflow_name'"
                stopped_count=$((stopped_count + 1))
            else
                print_warning "Failed to stop workflow '$workflow_name'"
            fi
        fi
    done < <(echo "$running_runs" | jq -r '.[] | "\(.databaseId)|\(.id)|\(.workflowName)"')
    
    print_success "Stopped $stopped_count workflow(s)"
    
    # Wait a moment for workflows to fully stop
    if [ "$stopped_count" -gt 0 ]; then
        print_info "Waiting for workflows to fully stop..."
        sleep 5
    fi
}

# Function to remove all VMware runners
# NOTE: This function only removes GitHub runner registrations, NOT the actual VMs
# VMware VMs should never be deleted by this script
remove_all_vmware_runners() {
    print_info "Removing VMware runner registrations from GitHub (VMs are preserved)..."
    print_warning "VMware VMs are NOT deleted - they remain on $VMWARE_SSH_HOST for manual management"
    
    # Only remove GitHub runner registrations via API
    # The actual VMs remain untouched on darkstar
    print_info "VMware runner VMs are preserved and must be managed manually on $VMWARE_SSH_HOST"
}

# Function to remove all runners
remove_all_runners() {
    print_info "Removing all GitHub runners using GitHub API..."

    # Remove all VMware VMs (remote cleanup)
    remove_all_vmware_runners

    # Remove all runners from GitHub via API
    while :; do
        local runners
        local gh_cmd="gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners --jq '.runners[] | @base64'"
        runners=$(eval $gh_cmd 2>/dev/null)
        if [ $? -ne 0 ]; then
            print_error "Failed to fetch runners from GitHub API. Aborting runner removal."
            print_info "Command attempted: $gh_cmd"
            return 1
        fi
        if [ -z "$runners" ]; then
            print_success "No runners found in GitHub API. All runners removed."
            break
        fi

        echo "$runners" | while read -r runner; do
            [ -z "$runner" ] && continue
            _jq() { echo "$runner" | base64 --decode | jq -r "$1"; }
            id=$(_jq '.id')
            name=$(_jq '.name')
            status=$(_jq '.status')
            if [ -n "$id" ]; then
                print_info "Removing runner '$name' (ID: $id, Status: $status)..."
                gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners/$id --method DELETE || print_error "Failed to delete runner $name (ID: $id)"
                sleep 1
            fi
        done

        sleep 2
    done
}

# Function to remove runners directly from GitHub API
remove_runners_from_github_api() {
    print_info "Removing runners directly from GitHub API..."
    
    # Get list of registered runners
    local runners_json
    runners_json=$(gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners --jq '.runners' 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch runners from GitHub API"
        return 1
    fi
    
    local runner_count
    runner_count=$(echo "$runners_json" | jq 'length' 2>/dev/null)
    
    if [ "$runner_count" = "0" ] || [ -z "$runner_count" ]; then
        print_info "No runners found in GitHub API"
        return 0
    fi
    
    print_info "Found $runner_count runner(s) to remove from GitHub API"
    
    # Remove each runner
    local removed_count=0
    while IFS='|' read -r runner_id runner_name; do
        if [ -n "$runner_id" ] && [ -n "$runner_name" ]; then
            print_info "Removing runner '$runner_name' (ID: $runner_id) from GitHub API..."
            
            # Remove runner using GitHub API
            if gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners/$runner_id --method DELETE 2>/dev/null; then
                print_success "Successfully removed runner '$runner_name' from GitHub API"
                removed_count=$((removed_count + 1))
            else
                print_warning "Failed to remove runner '$runner_name' from GitHub API"
            fi
        fi
    done < <(echo "$runners_json" | jq -r '.[] | "\(.id)|\(.name)"')
    
    print_success "Removed $removed_count runner(s) from GitHub API"
    
    # Wait and verify that runners are actually removed
    if [ "$removed_count" -gt 0 ]; then
        wait_for_runners_removal
    fi
}

# Function to wait and verify that runners are removed from GitHub
wait_for_runners_removal() {
    print_info "Waiting for runners to be removed from GitHub..."
    
    local max_attempts=30  # 30 attempts * 2 seconds = 60 seconds max wait
    local attempt=0
    
    while [ $attempt -lt $max_attempts ]; do
        attempt=$((attempt + 1))
        
        # Check if any runners still exist
        local remaining_runners
        remaining_runners=$(gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners --jq '.runners | length' 2>/dev/null)
        
        if [ $? -ne 0 ]; then
            print_warning "Failed to check remaining runners (attempt $attempt/$max_attempts)"
            sleep 2
            continue
        fi
        
        if [ "$remaining_runners" = "0" ] || [ -z "$remaining_runners" ]; then
            print_success "All runners successfully removed from GitHub (confirmed after $((attempt * 2)) seconds)"
            return 0
        else
            print_info "Still waiting for $remaining_runners runner(s) to be removed... (attempt $attempt/$max_attempts)"
            sleep 2
        fi
    done
    
    print_warning "Timeout waiting for runners to be removed from GitHub after $((max_attempts * 2)) seconds"
    print_info "Some runners may still appear in the GitHub web UI temporarily"
    return 1
}

# Function to stop workflows running on a specific runner
stop_workflows_for_runner() {
    local runner_name=$1
    print_info "Stopping workflows running on runner: $runner_name"
    
    # Generate GitHub token to ensure we have auth and repo context
    generate_runner_token
    
    # Get list of in-progress workflow runs
    local running_runs
    running_runs=$(gh run list --status in_progress --json databaseId,id,workflowName,status --limit 100 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch running workflows for $GITHUB_OWNER/$GITHUB_REPO"
        return 1
    fi
    
    local run_count
    run_count=$(echo "$running_runs" | jq 'length' 2>/dev/null)
    
    if [ "$run_count" = "0" ] || [ -z "$run_count" ]; then
        print_info "No running workflows found"
        return 0
    fi
    
    # Check if any workflows are running on this specific runner
    local runner_workflows=0
    local stopped_count=0
    
    echo "$running_runs" | jq -r '.[] | "\(.databaseId)|\(.id)|\(.workflowName)"' | while IFS='|' read -r run_id workflow_id workflow_name; do
        if [ -n "$run_id" ] && [ -n "$workflow_id" ]; then
            # Get detailed run info to check which runner it's using
            local run_info
            run_info=$(gh run view "$workflow_id" --json jobs 2>/dev/null)
            
            if [ $? -eq 0 ]; then
                # Check if any job in this run is using the specific runner
                local using_runner
                using_runner=$(echo "$run_info" | jq -r '.jobs[] | select(.runner_name == "'$runner_name'") | .id' 2>/dev/null)
                
                if [ -n "$using_runner" ]; then
                    runner_workflows=$((runner_workflows + 1))
                    print_info "Stopping workflow '$workflow_name' (ID: $workflow_id) running on $runner_name..."
                    
                    # Cancel the workflow run
                    if gh run cancel "$workflow_id" 2>/dev/null; then
                        print_success "Successfully stopped workflow '$workflow_name'"
                        stopped_count=$((stopped_count + 1))
                    else
                        print_warning "Failed to stop workflow '$workflow_name'"
                    fi
                fi
            fi
        fi
    done
    
    if [ "$runner_workflows" -gt 0 ]; then
        print_success "Stopped $stopped_count workflow(s) running on $runner_name"
        
        # Wait a moment for workflows to fully stop
        if [ "$stopped_count" -gt 0 ]; then
            print_info "Waiting for workflows to fully stop..."
            sleep 5
        fi
    else
        print_info "No workflows found running on $runner_name"
    fi
}

# Function to remove/de-register a GitHub runner
remove_runner() {
    local runner_name=$1
    local vmware_vm_name="runner-${runner_name}"
    print_info "Removing GitHub runner: $runner_name"

    # Stop workflows running on this runner first
    stop_workflows_for_runner "$runner_name"

    # Determine runner type and target
    local runner_found=false
    local runner_type=""
    local lima_instance=""

    # Check if it's a Lima runner (map label → instance name)
    lima_instance=$(get_lima_instance_for_label "$runner_name")
    if [ -n "$lima_instance" ]; then
        runner_type="lima"
        runner_found=true
        print_info "Identified as Lima runner: instance '$lima_instance'"
    # Check if it's a VMware VM
    elif vmware_vm_exists "$vmware_vm_name"; then
        print_info "Found VMware runner VM: $vmware_vm_name"
        runner_type="vmware"
        local vm_hostname
        vm_hostname=$(get_vmware_vm_hostname "$runner_name")
        local vm_path
        vm_path=$(get_vmware_vm_path "$vmware_vm_name")
        local running_vms
        running_vms=$(ssh "$VMWARE_SSH_HOST" "'$VMWARE_VMRUN_PATH' list" 2>/dev/null)
        if echo "$running_vms" | grep -q "$vm_path"; then
            runner_found=true
        else
            runner_found="stopped"
        fi
    fi

    if [ "$runner_found" = false ]; then
        print_warning "Could not locate runner '$runner_name' (not a known Lima instance or VMware VM)"
        print_info "To manually remove from GitHub: go to repository Settings → Actions → Runners"
        return 0
    fi

    # ── Lima runner cleanup ────────────────────────────────────────────────────
    if [ "$runner_type" = "lima" ]; then
        local ssh_config="$HOME/.lima/$lima_instance/ssh.config"
        local ssh_target="lima-$lima_instance"

        # Check if instance is running
        local instance_status
        instance_status=$("$LIMACTL_PATH" list 2>/dev/null | awk -v name="$lima_instance" '$1 == name {print $2}')

        if [ "$instance_status" = "Running" ] && [ -f "$ssh_config" ]; then
            print_info "Stopping runner service on $lima_instance..."
            ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
                "cd /opt/actions-runner && ./svc.sh stop" 2>/dev/null \
                || print_warning "Runner service may not be running"

            print_info "Uninstalling runner service..."
            ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
                "cd /opt/actions-runner && ./svc.sh uninstall" 2>/dev/null \
                || print_warning "Runner service may not be installed"

            print_info "De-registering runner from GitHub..."
            ssh -F "$ssh_config" -o StrictHostKeyChecking=no "$ssh_target" \
                "cd /opt/actions-runner && ./config.sh remove --token '$RUNNER_TOKEN'" 2>/dev/null \
                || print_warning "Could not de-register via config.sh; will clean up via GitHub API"
        else
            print_warning "Lima instance '$lima_instance' is not running — skipping in-VM cleanup"
            print_info "GitHub runner registration will be removed via API"
        fi

        print_warning "════════════════════════════════════════════════════════════════"
        print_warning "  LIMA VM PRESERVATION"
        print_warning "════════════════════════════════════════════════════════════════"
        print_warning ""
        print_warning "  Lima instance '$lima_instance' is NOT stopped or deleted."
        print_warning "  Only the GitHub Actions runner registration has been removed."
        print_warning "  To stop the VM: limactl stop $lima_instance"
        print_warning ""
        print_warning "════════════════════════════════════════════════════════════════"

        print_success "Runner '$runner_name' de-registered (Lima instance preserved)"
        return 0
    fi

    # ── VMware runner cleanup (unchanged) ─────────────────────────────────────
    if [ "$runner_type" = "vmware" ]; then
        if [ "$runner_found" = true ]; then
            local ssh_target="$VMWARE_VM_USER@$vm_hostname"
            if test_ssh_connection_with_retries "$vm_hostname" true 2>/dev/null; then
                if $LEGACY_SSH_CMD "${LEGACY_SSH_OPTS[@]}" "$ssh_target" "test -d /opt/actions-runner" 2>/dev/null; then
                    $LEGACY_SSH_CMD "${LEGACY_SSH_OPTS[@]}" "$ssh_target" \
                        "cd /opt/actions-runner && ./svc.sh stop" 2>/dev/null \
                        || print_warning "Service may not be running"
                    $LEGACY_SSH_CMD "${LEGACY_SSH_OPTS[@]}" "$ssh_target" \
                        "cd /opt/actions-runner && ./svc.sh uninstall" 2>/dev/null \
                        || print_warning "Service may not be installed"
                    $LEGACY_SSH_CMD "${LEGACY_SSH_OPTS[@]}" "$ssh_target" \
                        "cd /opt/actions-runner && ./config.sh remove --token '$RUNNER_TOKEN'" 2>/dev/null \
                        || print_warning "Could not de-register via config.sh"
                fi
            fi
        fi

        print_warning "════════════════════════════════════════════════════════════════"
        print_warning "  VMWARE VM PRESERVATION"
        print_warning "════════════════════════════════════════════════════════════════"
        print_warning ""
        print_warning "  VMware VM '$vmware_vm_name' is NOT deleted."
        print_warning "  The VM remains on $VMWARE_SSH_HOST for manual management."
        print_warning ""
        print_warning "════════════════════════════════════════════════════════════════"

        print_success "Runner '$runner_name' removal completed (VMware VM preserved)"
    fi
}

# Function to validate runner name
validate_runner_name() {
    local runner_name=$1
    local runner_type=$2
    
    if [ -z "$runner_name" ]; then
        print_error "Runner name is required for $runner_type"
        usage
        exit 1
    fi
    
    # Basic validation - can be enhanced
    if [[ ! "$runner_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        print_error "Invalid runner name: $runner_name. Use only letters, numbers, hyphens, and underscores."
        exit 1
    fi
}

# Function to list registered runners for the repository
list_runners() {
    print_info "Listing GitHub runners for repository..."
    
    # Generate token to ensure we have auth and repo context
    generate_runner_token
    
    print_info "Repository: $GITHUB_OWNER/$GITHUB_REPO"
    print_info "Fetching registered runners..."
    
    # Use gh CLI to list runners
    local runners_json
    runners_json=$(gh api repos/$GITHUB_OWNER/$GITHUB_REPO/actions/runners --jq '.runners' 2>/dev/null)
    
    if [ $? -ne 0 ]; then
        print_error "Failed to fetch runners for $GITHUB_OWNER/$GITHUB_REPO. Check your permissions."
        print_info "Make sure you have admin access to the repository or 'Manage runners' permission."
        return 1
    fi
    
    # Parse and display runner information
    local runner_count
    runner_count=$(echo "$runners_json" | jq 'length' 2>/dev/null)
    
    if [ "$runner_count" = "0" ] || [ -z "$runner_count" ]; then
        print_warning "No runners found for repository $GITHUB_OWNER/$GITHUB_REPO"
        return 0
    fi
    
    print_success "Found $runner_count registered runner(s):"
    echo
    echo "GitHub Repository: $GITHUB_OWNER/$GITHUB_REPO"
    echo "=================================================================================="
    printf "%-20s %-15s %-10s %-20s %s\n" "NAME" "STATUS" "BUSY" "OS" "LABELS"
    echo "=================================================================================="
    
    # Display each runner
    echo "$runners_json" | jq -r '.[] | "\(.name)|\(.status)|\(.busy)|\(.os)|\(.labels | map(.name) | join(","))"' | while IFS='|' read -r name status busy os labels; do
        printf "%-20s %-15s %-10s %-20s %s\n" "$name" "$status" "$busy" "$os" "$labels"
    done
    
    echo
    print_info "Use '$0 -remove <runner_name>' to remove a specific runner"
}

# Main script logic
main() {
    # Check for help flag first (before dependency check)
    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            usage
            exit 0
        fi
    done
    
    # Check dependencies
    check_dependencies
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -lima)
                RUNNER_TYPE="lima"
                shift
                if [[ $# -gt 0 && ! $1 =~ ^- ]]; then
                    RUNNER_NAME="$1"
                    shift
                fi
                ;;
            -vmware)
                RUNNER_TYPE="vmware"
                shift
                if [[ $# -gt 0 && ! $1 =~ ^- ]]; then
                    RUNNER_NAME="$1"
                    shift
                fi
                ;;
            -r)
                RUNNER_NAME="$2"
                shift 2
                ;;
            -ssh)
                SSH_HOST="$2"
                shift 2
                ;;
            -start-all)
                ACTION="start-all"
                shift
                ;;
            -remove-all)
                ACTION="remove-all"
                shift
                ;;
            -remove)
                ACTION="remove"
                RUNNER_NAME="$2"
                shift 2
                ;;
            -cancel-workflows)
                ACTION="cancel-workflows"
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -owner)
                GITHUB_OWNER="$2"
                shift 2
                ;;
            -repo)
                GITHUB_REPO="$2"
                shift 2
                ;;
            -list)
                ACTION="list"
                shift
                ;;
            -debug)
                DEBUG_MODE="true"
                shift
                ;;
            -start-group)
                ACTION="start-group"
                GROUP="$2"
                shift 2
                ;;
            -stop-group)
                ACTION="stop-group"
                GROUP="$2"
                shift 2
                ;;
            -stop-vms)
                STOP_VMS="true"
                shift
                ;;
            -inspect-legacy-vms)
                ACTION="inspect-legacy-vms"
                shift
                ;;
            -vmware-api-host)
                VMWARE_REST_API_HOST="$2"
                shift 2
                ;;
            -vmware-api-port)
                VMWARE_REST_API_PORT="$2"
                shift 2
                ;;
            -vmware-api-user)
                VMWARE_REST_API_USER="$2"
                shift 2
                ;;
            -vmware-api-pass)
                VMWARE_REST_API_PASS="$2"
                shift 2
                ;;
            *)
                print_error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
    
    # Validate arguments
    if [ -z "$ACTION" ] && [ -z "$RUNNER_TYPE" ]; then
        print_error "No action specified"
        usage
        exit 1
    fi
    
    if [ -n "$RUNNER_TYPE" ] && [ -z "$RUNNER_NAME" ]; then
        print_error "Runner name is required when specifying runner type"
        usage
        exit 1
    fi
    
    # Execute action
    case $ACTION in
        "start-all")
            start_all_runners
            ;;
        "remove-all")
            remove_all_runners
            ;;
        "remove")
            if [ -z "$RUNNER_NAME" ]; then
                print_error "Runner name is required for remove operation"
                usage
                exit 1
            fi
            generate_runner_token
            remove_runner "$RUNNER_NAME"
            ;;
        "cancel-workflows")
            stop_all_workflows
            ;;
        "list")
            list_runners
            ;;
        "start-group")
            if [ -z "$GROUP" ]; then
                print_error "Group name is required for start-group operation"
                usage
                exit 1
            fi
            start_runner_group "$GROUP"
            ;;
        "stop-group")
            if [ -z "$GROUP" ]; then
                print_error "Group name is required for stop-group operation"
                usage
                exit 1
            fi
            stop_runner_group "$GROUP" "$STOP_VMS"
            ;;
        "inspect-legacy-vms")
            inspect_legacy_vms
            ;;
        "")
            # Start specific runner
            validate_runner_name "$RUNNER_NAME" "$RUNNER_TYPE"
            generate_runner_token
            
            case $RUNNER_TYPE in
                "lima")
                    start_lima_runner "$RUNNER_NAME"
                    ;;
                "vmware")
                    start_vmware_runner "$RUNNER_NAME"
                    ;;
                *)
                    print_error "Unknown runner type: $RUNNER_TYPE"
                    exit 1
                    ;;
            esac
            ;;
    esac
    
    print_success "Operation completed"
}

# Run main function with all arguments
main "$@" 