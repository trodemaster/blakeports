  * Create and start thread.
  **/
 void CCirrus::start_threads() {
+#if defined(__APPLE__)
+  /* Cocoa requires all GUI calls on the process main thread; the GUI
+     loop is driven from CSystem::Run() via run_gui_step() instead of
+     a device thread. Initialize the GUI eagerly here (start_threads
+     runs on the main thread) so the SDL screen exists before the CPU
+     threads are released and the guest VGA BIOS starts programming
+     the card. */
+  printf(" cirrus(main)");
+  StopThread = false;
+  if (!GuiInitialized) {
+    bx_gui->init(state.x_tilesize, state.y_tilesize);
+    GuiInitialized = true;
+  }
+#else
   if (!myThread) {
     printf(" cirrus");
     StopThread = false;
     myThread = std::make_unique<std::thread>([this](){ this->run(); });
+  }
+#endif
+}
+
+/**
+ * Run one iteration of the GUI loop on the calling thread. This is
+ * one pass of the run() loop body, used on macOS where the GUI must
+ * be driven from the process main thread.
+ **/
+bool CCirrus::run_gui_step() {
+  if (StopThread)
+    return false;
+  if (!GuiInitialized) {
+    bx_gui->init(state.x_tilesize, state.y_tilesize);
+    GuiInitialized = true;
+  }
+  // Handle GUI events (100 times per second)
+  for (int i = 0; i < 10; i++) {
+    bx_gui->lock();
+    bx_gui->handle_events();
+    bx_gui->unlock();
+    std::this_thread::sleep_for(std::chrono::milliseconds(10));
   }
+  // Update the screen (10 times per second)
+  bx_gui->lock();
+  update();
+  bx_gui->flush();
+  bx_gui->unlock();
+  return true;
 }
 
